<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="client-body">
<div class="client-app">
  <%- include('partials/sidebar') %>
  <div class="client-main">
    <header class="client-topbar">
      <nav class="client-topbar__breadcrumb">
        <strong>Dashboard</strong>
      </nav>
    </header>
    <div class="client-content client-content--dashboard">
      <%- include('partials/flash') %>

      <section class="dash-hero" aria-labelledby="dash-hero-title">
        <div class="dash-hero__glow" aria-hidden="true"></div>
        <div class="dash-hero__inner">
          <div class="dash-hero__identity">
            <div class="dash-hero__avatar" aria-hidden="true"><%= String(clientName || 'C').trim().charAt(0).toUpperCase() %></div>
            <div class="dash-hero__text">
              <p class="dash-hero__eyebrow">Client portal</p>
              <h1 id="dash-hero-title" class="dash-hero__title"><%= clientName %></h1>
              <% if (displayCompany) { %>
                <p class="dash-hero__company"><%= displayCompany %></p>
              <% } %>
            </div>
          </div>
          <div class="dash-hero__pills">
            <% if (startDate && startDateFmt) { %>
              <span class="dash-hero__pill">
                <svg class="dash-hero__pill-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                Active since <%= startDateFmt %>
              </span>
            <% } %>
            <span class="dash-hero__pill">
              <svg class="dash-hero__pill-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <%= accessCount %> access <%= accessCount === 1 ? 'entry' : 'entries' %>
            </span>
            <a class="dash-hero__pill dash-hero__pill--link" href="/client/financials">
              Financials →
            </a>
          </div>
        </div>
      </section>

      <% if (startDate && uptimeTotalSecs != null) { %>
        <div
          class="dash-uptime-panel"
          id="dash-uptime"
          data-total-secs="<%= uptimeTotalSecs %>"
          aria-live="polite"
        >
          <div class="dash-uptime-panel__head">
            <span class="dash-uptime-panel__live"><span class="dash-uptime-panel__dot" aria-hidden="true"></span></span>
            <svg class="dash-uptime-panel__zap" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <span class="dash-uptime-panel__label">System live · Uptime</span>
          </div>
          <div class="dash-uptime-panel__row">
            <div class="dash-uptime-panel__blocks">
              <div class="dash-uptime-panel__block">
                <span class="dash-uptime-panel__num" id="up-days"><%= uptimeDays %></span>
                <span class="dash-uptime-panel__unit">Days</span>
              </div>
              <div class="dash-uptime-panel__block">
                <span class="dash-uptime-panel__num" id="up-hours"><%= String(uptimeHours).padStart(2, '0') %></span>
                <span class="dash-uptime-panel__unit">Hours</span>
              </div>
              <div class="dash-uptime-panel__block">
                <span class="dash-uptime-panel__num" id="up-mins"><%= String(uptimeMins).padStart(2, '0') %></span>
                <span class="dash-uptime-panel__unit">Minutes</span>
              </div>
              <div class="dash-uptime-panel__block">
                <span class="dash-uptime-panel__num" id="up-secs"><%= String(uptimeSecsRem).padStart(2, '0') %></span>
                <span class="dash-uptime-panel__unit">Seconds</span>
              </div>
            </div>
            <div class="dash-uptime-panel__aside">
              <p class="dash-uptime-panel__line">Active since <strong><%= startDateFmt %></strong></p>
              <% if (uptimeSource === 'payment') { %>
                <p class="dash-uptime-panel__hint">Based on your earliest recorded payment. Your admin can set a fixed “active since” date on your account.</p>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>

      <div class="dash-metrics">
        <article class="dash-metric dash-metric--a">
          <div class="dash-metric__top">
            <span class="dash-metric__label">Access</span>
            <span class="dash-metric__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
          </div>
          <p class="dash-metric__value"><%= accessCount %></p>
          <p class="dash-metric__sub">Servers, databases &amp; services</p>
        </article>
        <article class="dash-metric dash-metric--b">
          <div class="dash-metric__top">
            <span class="dash-metric__label">Paid (recorded)</span>
            <span class="dash-metric__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </span>
          </div>
          <div class="dash-metric__values">
            <% paidTotalLines.forEach(function (line) { %>
              <div class="dash-metric__row">
                <span class="dash-metric__ccy"><%= line.currency %></span>
                <span class="dash-metric__amount"><%= line.amountFmt %></span>
              </div>
            <% }); %>
          </div>
          <p class="dash-metric__sub">Paid payments + maintenance · by currency</p>
        </article>
        <article class="dash-metric dash-metric--c">
          <div class="dash-metric__top">
            <span class="dash-metric__label">Pending</span>
            <span class="dash-metric__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </span>
          </div>
          <div class="dash-metric__values">
            <% pendingTotalLines.forEach(function (line) { %>
              <div class="dash-metric__row">
                <span class="dash-metric__ccy"><%= line.currency %></span>
                <span class="dash-metric__amount"><%= line.amountFmt %></span>
              </div>
            <% }); %>
          </div>
          <p class="dash-metric__sub">Outstanding items</p>
        </article>
      </div>

      <div class="dash-recents">
        <section class="dash-recent-panel" aria-labelledby="recent-pay-title">
          <div class="dash-recent-panel__head">
            <h2 id="recent-pay-title" class="dash-recent-panel__title">Recent payments</h2>
            <a href="/client/financials" class="dash-recent-panel__link">View all</a>
          </div>
          <% if (recentPayments.length) { %>
            <ul class="dash-recent-list">
              <% recentPayments.forEach(function (row) { %>
                <li class="dash-recent-item">
                  <div class="dash-recent-item__main">
                    <span class="dash-recent-item__date"><%= row.dateFmt %></span>
                    <div class="dash-recent-item__tail">
                      <span class="dash-recent-item__amount"><%= row.amountFmt %></span>
                      <span class="dash-recent-badge dash-recent-badge--<%= row.status === 'paid' ? 'paid' : 'pending' %>"><%= row.status === 'paid' ? 'Paid' : 'Pending' %></span>
                    </div>
                  </div>
                  <% if (row.title) { %>
                    <p class="dash-recent-item__meta dash-recent-item__meta--title"><%= row.title %></p>
                  <% } %>
                </li>
              <% }); %>
            </ul>
          <% } else { %>
            <p class="dash-recent-empty">No payment lines yet.</p>
          <% } %>
        </section>

        <section class="dash-recent-panel" aria-labelledby="recent-maint-title">
          <div class="dash-recent-panel__head">
            <h2 id="recent-maint-title" class="dash-recent-panel__title">Recent maintenance</h2>
            <a href="/client/maintenance" class="dash-recent-panel__link">View all</a>
          </div>
          <% if (recentMaintenance.length) { %>
            <ul class="dash-recent-list">
              <% recentMaintenance.forEach(function (row) { %>
                <li class="dash-recent-item dash-recent-item--maint">
                  <div class="dash-recent-item__main">
                    <span class="dash-recent-item__date"><%= row.periodShort %></span>
                    <div class="dash-recent-item__tail">
                      <span class="dash-recent-item__amount"><%= row.costFmt %></span>
                      <span class="dash-maint-lv dash-maint-lv--<%= row.level %>">L<%= row.level %></span>
                    </div>
                  </div>
                  <p class="dash-recent-item__meta dash-recent-item__meta--title"><%= row.title %></p>
                </li>
              <% }); %>
            </ul>
          <% } else { %>
            <p class="dash-recent-empty">No maintenance logs yet.</p>
          <% } %>
        </section>
      </div>

    </div>
  </div>
</div>

<script>
(function () {
  var el = document.getElementById('dash-uptime');
  if (!el) return;
  var totalSecs = parseInt(el.getAttribute('data-total-secs'), 10);
  if (!Number.isFinite(totalSecs) || totalSecs < 0) totalSecs = 0;

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    totalSecs++;
    var s = totalSecs % 60;
    var tm = Math.floor(totalSecs / 60);
    var th = Math.floor(tm / 60);
    var td = Math.floor(th / 24);
    var dEl = document.getElementById('up-days');
    var hEl = document.getElementById('up-hours');
    var mEl = document.getElementById('up-mins');
    var sEl = document.getElementById('up-secs');
    if (dEl) dEl.textContent = String(td);
    if (hEl) hEl.textContent = pad(th % 24);
    if (mEl) mEl.textContent = pad(tm % 60);
    if (sEl) sEl.textContent = pad(s);
  }

  setInterval(tick, 1000);
})();
</script>
</body>
</html>
