<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="client-body">
<div class="client-app">
  <%- include('partials/sidebar') %>
  <div class="client-main">
    <header class="client-topbar">
      <nav class="client-topbar__breadcrumb" aria-label="Section">
        <strong>Maintenance</strong>
      </nav>
    </header>
    <div class="client-content client-content--maintenance">
      <%- include('partials/flash') %>

      <header class="client-page-hero client-page-hero--card maint-page-head">
        <% var byLevel = cards.length ? [1,2,3,4].map(function(l){ return { level: l, count: cards.filter(function(c){ return c.level == l; }).length }; }).filter(function(x){ return x.count > 0; }) : []; %>
        <div class="client-page-hero__card<%= cards.length ? ' client-page-hero__card--split' : '' %>">
          <div class="client-page-hero__main">
            <h1 class="client-page-hero__title">Billing-period log</h1>
            <p class="client-page-hero__lead">Level, cost, and scope by period—open a card for full notes.</p>
          </div>
          <% if (cards.length) { %>
            <div class="client-page-hero__aside" aria-label="Summary">
              <div class="client-hero-mini-grid">
                <div class="client-hero-mini">
                  <span class="client-hero-mini__value"><%= cards.length %></span>
                  <span class="client-hero-mini__label">Periods</span>
                </div>
                <% byLevel.forEach(function(x) { %>
                  <div class="client-hero-mini client-hero-mini--lv<%= x.level %>">
                    <span class="client-hero-mini__value">L<%= x.level %></span>
                    <span class="client-hero-mini__label"><%= x.count %></span>
                  </div>
                <% }); %>
              </div>
            </div>
          <% } %>
        </div>
      </header>

      <% if (typeof hasLogsOverall !== 'undefined' && hasLogsOverall) { %>
        <div class="maint-toolbar-wrap">
          <form method="get" action="/client/maintenance" class="maint-toolbar" aria-label="Filter by billing period">
            <div class="maint-toolbar__fields">
              <label class="maint-toolbar__field">
                <span class="maint-toolbar__label">From period</span>
                <input type="month" name="periodFrom" class="maint-toolbar__input" value="<%= typeof filterPeriodFrom !== 'undefined' ? filterPeriodFrom : '' %>" />
              </label>
              <label class="maint-toolbar__field">
                <span class="maint-toolbar__label">To period</span>
                <input type="month" name="periodTo" class="maint-toolbar__input" value="<%= typeof filterPeriodTo !== 'undefined' ? filterPeriodTo : '' %>" />
              </label>
            </div>
            <div class="maint-toolbar__actions">
              <button type="submit" class="maint-toolbar__btn maint-toolbar__btn--primary">Apply range</button>
              <% if (typeof filterPeriodActive !== 'undefined' && filterPeriodActive) { %>
                <a href="/client/maintenance" class="maint-toolbar__btn maint-toolbar__btn--ghost">Clear</a>
              <% } %>
            </div>
          </form>
          <% if (typeof filterPeriodActive !== 'undefined' && filterPeriodActive) { %>
            <p class="maint-toolbar__hint">Showing billing periods that fall in this month range.</p>
          <% } %>
        </div>
      <% } %>

      <% if (cards.length) { %>
        <script type="application/json" id="maint-json-data"><%- JSON.stringify(cards.map(function(c) {
          return { id: c.id, title: c.title, periodLabel: c.periodLabel, refCode: c.refCode, level: c.level, costFmt: c.costFmt, details: c.details || '', summary: c.summary || '' };
        })) %></script>

        <% maintYears.forEach(function(yr) { %>
          <section class="maint-year" aria-label="Maintenance <%= yr.year %>">
            <div class="maint-year__bar">
              <span class="maint-year__pill maint-year__pill--p<%= (yr.year % 3) %>"><%= yr.year %></span>
              <span class="maint-year__rule" aria-hidden="true"></span>
              <div class="maint-year__stats">
                <span class="maint-year__count"><%= yr.count %> <%= yr.count === 1 ? 'period' : 'periods' %></span>
                <% if (yr.yearTotalLines && yr.yearTotalLines.length) { %>
                  <span class="maint-year__sep" aria-hidden="true">·</span>
                  <span class="maint-year__amounts">
                    <% yr.yearTotalLines.forEach(function(line, i) { %>
                      <% if (i) { %><span class="maint-year__between" aria-hidden="true">·</span><% } %>
                      <span class="maint-year__amt"><%= line.amountFmt %></span>
                    <% }); %>
                  </span>
                <% } %>
              </div>
            </div>

            <div class="maint-inv-grid">
              <% yr.cards.forEach(function(c) { %>
                <article class="maint-inv-card" data-id="<%= c.id %>">
                  <div class="maint-inv-card__head maint-inv-card__head--p<%= c.paletteIdx %>">
                    <div class="maint-inv-card__head-deco" aria-hidden="true"></div>
                    <div class="maint-inv-card__head-row">
                      <div>
                        <p class="maint-inv-card__ref"><%= c.refCode %></p>
                        <p class="maint-inv-card__month"><%= c.shortMonth %></p>
                        <p class="maint-inv-card__year"><%= c.year %></p>
                      </div>
                      <div class="maint-inv-card__receipt" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 17V7"/></svg>
                      </div>
                    </div>
                  </div>
                  <div class="maint-inv-card__body">
                    <p class="maint-inv-card__block-label">Title</p>
                    <h3 class="maint-inv-card__title"><%= c.title %></h3>
                    <div class="maint-inv-card__amount-row">
                      <div>
                        <span class="maint-inv-card__amount-label">Amount</span>
                        <p class="maint-inv-card__amount"><%= c.costFmt %></p>
                      </div>
                      <span class="maint-inv-card__lv-pill maint-inv-card__lv-pill--<%= c.level %>">Level <%= c.level %></span>
                    </div>
                    <div class="maint-inv-card__divider"></div>
                    <dl class="maint-inv-card__kv">
                      <div class="maint-inv-card__kv-row">
                        <dt>Billing period</dt>
                        <dd><%= c.periodLabel %></dd>
                      </div>
                      <div class="maint-inv-card__kv-row">
                        <dt>Last updated</dt>
                        <dd><%= c.loggedAtFmt %></dd>
                      </div>
                    </dl>
                    <button type="button" class="maint-inv-card__details js-maint-open" data-id="<%= c.id %>">View details</button>
                  </div>
                </article>
              <% }); %>
            </div>
          </section>
        <% }); %>

      <% } else if (typeof hasLogsOverall !== 'undefined' && hasLogsOverall && typeof filterPeriodActive !== 'undefined' && filterPeriodActive) { %>
        <div class="maint-empty maint-empty--filter">
          <div class="maint-empty__mark" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h10M4 18h16"/></svg>
          </div>
          <h2 class="maint-empty__title">No periods in this range</h2>
          <p class="maint-empty__text">Try different months or <a href="/client/maintenance">clear the filter</a> to see all logs.</p>
        </div>
      <% } else { %>
        <div class="maint-empty">
          <div class="maint-empty__mark" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h2 class="maint-empty__title">No maintenance records yet</h2>
          <p class="maint-empty__text">When Qimora logs a maintenance or update cycle for your project, it will appear here.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div class="maint-overlay" id="maint-modal" role="dialog" aria-modal="true" aria-labelledby="maint-modal-title">
  <div class="maint-modal" role="document">
    <button type="button" class="maint-modal__close" id="maint-modal-close" aria-label="Close dialog">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <header class="maint-modal__banner">
      <div class="maint-modal__banner-deco" aria-hidden="true"></div>
      <div class="maint-modal__banner-row">
        <span class="maint-modal__badge" id="maint-modal-badge"></span>
        <span class="maint-modal__period" id="maint-modal-period"></span>
      </div>
      <p class="maint-modal__ref" id="maint-modal-ref"></p>
      <h2 class="maint-modal__title" id="maint-modal-title"></h2>
      <div class="maint-modal__amount-panel">
        <span class="maint-modal__amount-label">Amount</span>
        <p class="maint-modal__cost" id="maint-modal-cost"></p>
      </div>
    </header>

    <div class="maint-modal__body">
      <p class="maint-modal__section-label">Details</p>
      <div class="maint-modal__details" id="maint-modal-details"></div>
    </div>
  </div>
</div>

<script>
(function () {
  var overlay = document.getElementById('maint-modal');
  var dataEl = document.getElementById('maint-json-data');
  if (!overlay || !dataEl) return;

  var byId = {};
  try {
    JSON.parse(dataEl.textContent || '[]').forEach(function (row) { byId[row.id] = row; });
  } catch (e) {}

  var closeBtn = document.getElementById('maint-modal-close');
  var titleEl  = document.getElementById('maint-modal-title');
  var periodEl = document.getElementById('maint-modal-period');
  var refEl    = document.getElementById('maint-modal-ref');
  var badgeEl  = document.getElementById('maint-modal-badge');
  var costEl   = document.getElementById('maint-modal-cost');
  var detailsEl = document.getElementById('maint-modal-details');

  var LV_LABELS = { 1: 'Level 1 — Minor fixes', 2: 'Level 2 — Improvements', 3: 'Level 3 — Major update', 4: 'Level 4 — Full release' };

  function setBadgeLevel(lv) {
    badgeEl.textContent = LV_LABELS[lv] || ('Level ' + lv);
    badgeEl.className = 'maint-modal__badge maint-modal__badge--lv' + lv;
  }

  function openModal(id) {
    var row = byId[id] || {};
    window.clearTimeout(overlay._maintCloseT);

    titleEl.textContent = row.title || '';
    periodEl.textContent = row.periodLabel || '';
    var lv = String(row.level || '1');
    setBadgeLevel(lv);
    costEl.textContent = row.costFmt || '';
    if (refEl) {
      refEl.textContent = row.refCode ? row.refCode : '';
      refEl.hidden = !row.refCode;
    }

    var body = (row.details && String(row.details).trim()) ? row.details : (row.summary || 'No additional details.');
    detailsEl.textContent = body;

    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!overlay.classList.contains('is-open')) return;
    overlay.classList.remove('is-open');
    window.clearTimeout(overlay._maintCloseT);
    overlay._maintCloseT = window.setTimeout(function () {
      document.body.style.overflow = '';
    }, 300);
  }

  document.querySelectorAll('.js-maint-open').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      openModal(btn.getAttribute('data-id'));
    });
  });

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal();
  });
})();
</script>
</body>
</html>
