<!-- ─── SCRIPTS ───────────────────────────────────────────────── -->
<script>
(function () {

  /* ── Lucide init ── */
  if (window.lucide) lucide.createIcons();
  document.addEventListener('DOMContentLoaded', function () {
    if (window.lucide) lucide.createIcons();
    initCaseStudyPageNav();
  });

  function initCaseStudyPageNav() {
    var scroll = document.getElementById('csPageNavScroll');
    if (!scroll) return;

    var navOffset = 88;
    var sectionIds = ['cs-top', 'cs-overview', 'cs-solution', 'cs-results', 'cs-cta'];

    function getActiveId() {
      var y = window.scrollY + navOffset;
      var id = sectionIds[0];
      for (var i = 0; i < sectionIds.length; i++) {
        var el = document.getElementById(sectionIds[i]);
        if (!el) continue;
        var top = el.getBoundingClientRect().top + window.scrollY;
        if (top <= y) id = sectionIds[i];
      }
      return id;
    }

    function syncFromScroll() {
      var id = getActiveId();
      scroll.querySelectorAll('a[data-cs-page]').forEach(function (a) {
        var href = a.getAttribute('href') || '';
        var on = href === '#' + id;
        a.classList.toggle('is-active', on);
        if (on) a.setAttribute('aria-current', 'true');
        else a.removeAttribute('aria-current');
      });
    }

    window.addEventListener('scroll', syncFromScroll, { passive: true });
    window.addEventListener('resize', syncFromScroll);

    scroll.addEventListener('click', function (e) {
      var a = e.target.closest('a[data-cs-page]');
      if (!a || !scroll.contains(a)) return;
      var href = a.getAttribute('href');
      if (!href || href.charAt(0) !== '#') return;
      var target = document.getElementById(href.slice(1));
      if (!target) return;
      e.preventDefault();
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
      if (history.pushState) {
        try {
          history.pushState(null, '', href);
        } catch (err) {}
      }
      requestAnimationFrame(syncFromScroll);
    });

    syncFromScroll();
    var activeLink = scroll.querySelector('a.navbar-cs__tab.is-active');
    if (activeLink) {
      try {
        activeLink.scrollIntoView({ inline: 'center', block: 'nearest' });
      } catch (err) {}
    }
  }

  /* ── Scroll-reveal ── */
  const observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('cs-revealed');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.cs-module, .cs-feat, .cs-result, .cs-pill, .cs-detail-card, .cs-tech-card').forEach(function (el) {
    el.classList.add('cs-reveal');
    observer.observe(el);
  });

  /* ── Counter animation ── */
  function animateCounter(el) {
    const text = el.textContent.trim();
    const num = parseFloat(text.replace(/[^0-9.]/g, ''));
    if (isNaN(num) || num === 0) return;
    const suffix = text.replace(/[0-9.]/g, '');
    const dur = 1400;
    const start = performance.now();
    function step(now) {
      const t = Math.min((now - start) / dur, 1);
      const ease = 1 - Math.pow(1 - t, 3);
      const cur = Math.round(ease * num * 10) / 10;
      el.textContent = (cur % 1 === 0 ? cur : cur.toFixed(1)) + suffix;
      if (t < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  const resultObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.cs-result__val').forEach(animateCounter);
        resultObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('.cs-results').forEach(function (el) { resultObs.observe(el); });

})();


/* ─── Dual Viewer ─── */
var _shots   = <%- JSON.stringify(project.mobileScreenshots || []) %>;
var _webImgs = <%- JSON.stringify([project.image].concat(project.extraImages || [])) %>;
var _wi = 0; /* active web index  */
var _mi = 0; /* active mob index  */

/* helpers */
function _setActive(selector, index) {
  document.querySelectorAll(selector).forEach(function(el, i) {
    el.classList.toggle('cs-slide--active', i === index);
  });
}
function _setDot(containerId, index) {
  var c = document.getElementById(containerId);
  if (!c) return;
  c.querySelectorAll('.cs-dv-dot').forEach(function(d, i) {
    d.classList.toggle('cs-dv-dot--on', i === index);
  });
}

/* switch tabs */
function switchViewer(mode) {
  var pW = document.getElementById('panelWeb');
  var pM = document.getElementById('panelMobile');
  var tW = document.getElementById('tabWeb');
  var tM = document.getElementById('tabMobile');
  if (mode === 'mobile') {
    if (pW) pW.classList.add('cs-dv-panel--hidden');
    if (pM) pM.classList.remove('cs-dv-panel--hidden');
    if (tW) tW.classList.remove('cs-dv-tab--active');
    if (tM) tM.classList.add('cs-dv-tab--active');
  } else {
    if (pM) pM.classList.add('cs-dv-panel--hidden');
    if (pW) pW.classList.remove('cs-dv-panel--hidden');
    if (tM) tM.classList.remove('cs-dv-tab--active');
    if (tW) tW.classList.add('cs-dv-tab--active');
  }
}

/* web slider */
function goToWeb(i) {
  var total = _webImgs.length;
  if (i < 0) i = total - 1;
  if (i >= total) i = 0;
  _wi = i;
  _setActive('.cs-slide--web', i);
  _setDot('webDots', i);
}
function webNav(dir) { goToWeb(_wi + dir); }

/* mobile slider */
function goToMobile(i) {
  var total = _shots.length;
  if (i < 0) i = total - 1;
  if (i >= total) i = 0;
  _mi = i;
  _setActive('.cs-slide--mob', i);
  _setDot('mobileDots', i);
  var cur = document.getElementById('mobCur');
  var cap = document.getElementById('mobCaption');
  if (cur) cur.textContent = i + 1;
  if (cap) cap.textContent = (_shots[i] && _shots[i].caption) ? _shots[i].caption : '';
}
function mobileNav(dir) { goToMobile(_mi + dir); }

/* touch swipe on phone display */
(function() {
  var el = document.querySelector('.cs-phone2__display');
  if (!el) return;
  var sx = 0;
  el.addEventListener('touchstart', function(e){ sx = e.touches[0].clientX; }, { passive: true });
  el.addEventListener('touchend', function(e){
    var dx = e.changedTouches[0].clientX - sx;
    if (Math.abs(dx) > 36) mobileNav(dx < 0 ? 1 : -1);
  }, { passive: true });
})();

/* touch swipe on browser viewport */
(function() {
  var el = document.querySelector('.cs-browser-viewport');
  if (!el) return;
  var sx = 0;
  el.addEventListener('touchstart', function(e){ sx = e.touches[0].clientX; }, { passive: true });
  el.addEventListener('touchend', function(e){
    var dx = e.changedTouches[0].clientX - sx;
    if (Math.abs(dx) > 36) webNav(dx < 0 ? 1 : -1);
  }, { passive: true });
})();

/* scroll wheel on both viewers */
(function() {
  var bv = document.querySelector('.cs-browser-viewport');
  if (bv) bv.addEventListener('wheel', function(e){ e.preventDefault(); webNav(e.deltaY > 0 ? 1 : -1); }, { passive: false });
  var pd = document.querySelector('.cs-phone2__display');
  if (pd) pd.addEventListener('wheel', function(e){ e.preventDefault(); mobileNav(e.deltaY > 0 ? 1 : -1); }, { passive: false });
})();

</script>
