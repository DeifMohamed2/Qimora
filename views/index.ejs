            </div>

            <div class="dashboard__body">
              <div class="dashboard__header-row">
                <div>
                  <div class="dashboard__heading">Our Expertise</div>
                  <div class="dashboard__subheading">Technologies & Capabilities</div>
                </div>
                <div class="dashboard__status-badge">✦ Full-Stack Excellence</div>
              </div>

              <div class="dashboard__metrics">
                <div class="dashboard__metric">
                  <div class="dashboard__metric-value" style="color: #FF9F43; text-shadow: 0 0 12px #FF9F4355;">100%</div>
                  <div class="dashboard__metric-label">Project Delivery</div>
                </div>
                <div class="dashboard__metric">
                  <div class="dashboard__metric-value" style="color: #3B5BFF; text-shadow: 0 0 12px #3B5BFF55;">24/7</div>
                  <div class="dashboard__metric-label">Support Available</div>
                </div>
                <div class="dashboard__metric">
                  <div class="dashboard__metric-value" style="color: #FF9F43; text-shadow: 0 0 12px #FF9F4355;">4+</div>
                  <div class="dashboard__metric-label">Years Experience</div>
                </div>
              </div>

              <div class="dashboard__chart">
                <div class="dashboard__chart-header">
                  <span>Project Success Rate</span>
                  <span style="color: #FF9F43;">Excellent</span>
