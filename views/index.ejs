<%- include('partials/navbar') %>

<!-- ============================================================
     HERO SECTION
     ============================================================ -->
<section id="product" class="hero">
  <canvas id="hero-canvas" class="hero__canvas"></canvas>

  <!-- Ambient glows -->
  <div class="hero__glow hero__glow--top"></div>
  <div class="hero__glow hero__glow--bottom"></div>
  <div class="hero__glow hero__glow--center"></div>

  <!-- Subtle grid overlay -->
  <div class="hero__grid-overlay"></div>

  <div class="hero__content">

    <!-- Announcement badge -->
    <div class="anim-fade-up" data-delay="100">
      <a href="#" class="hero__badge">
        <span class="hero__badge-dot"></span>
        <span>Technology Solutions Partner</span>
        <span class="hero__badge-sep">—</span>
        <span class="hero__badge-highlight">Since 2021</span>
        <i data-lucide="arrow-right" class="hero__badge-arrow"></i>
      </a>
    </div>

    <!-- Headline -->
    <h1 class="hero__title anim-fade-up" data-delay="200">
      We Build Intelligent Systems.<br />
      <span class="hero__title--accent">You Focus on Growth.</span>
    </h1>

    <!-- Subheadline -->
    <p class="hero__subtitle anim-fade-up" data-delay="350">
      Qimora builds enterprise AI, software, and automation for scale.
    </p>

    <!-- CTA Buttons -->
    <div class="hero__buttons anim-fade-up" data-delay="500">
      <a href="#portfolio" class="btn btn--primary btn--glow-orange btn--hero">
        View Our Work
        <i data-lucide="arrow-right"></i>
      </a>
      <a href="#contact" class="btn btn--ghost btn--hero">
        <i data-lucide="message-circle" class="btn__icon-fill"></i>
        Get in Touch
      </a>
    </div>

    <!-- Trust line -->
    <div class="hero__trust anim-fade-up" data-delay="620">
      <span class="hero__trust-item">
        <i data-lucide="code-2" class="hero__trust-icon"></i>
        Full-Stack Development
      </span>
      <span class="hero__trust-sep"></span>
      <span class="hero__trust-item">
        <i data-lucide="cpu" class="hero__trust-icon"></i>
        AI Integration
      </span>
      <span class="hero__trust-sep"></span>
      <span class="hero__trust-item">
        <i data-lucide="layers" class="hero__trust-icon"></i>
        End-to-End Solutions
      </span>
    </div>

    <!-- Stats -->
    <div class="hero__stats anim-fade-up" data-delay="750">
      <div class="hero__stat">
        <div class="hero__stat-value">4<span class="hero__stat-plus">+</span></div>
        <div class="hero__stat-label">Years of Experience</div>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <div class="hero__stat-value">7<span class="hero__stat-plus">+</span></div>
        <div class="hero__stat-label">Projects Delivered</div>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <div class="hero__stat-value">12<span class="hero__stat-plus">+</span></div>
        <div class="hero__stat-label">Satisfied Clients</div>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <div class="hero__stat-value">5</div>
        <div class="hero__stat-label">Expert Team Members</div>
      </div>
    </div>

  </div>

  <div class="hero__bottom-fade"></div>
</section>


<!-- ============================================================
     SERVICES SECTION
     ============================================================ -->
<section id="features" class="features">
  <div class="features__container">

    <div class="features__header anim-fade-up">
      <span class="badge badge--blue">What We Do</span>
      <h2 class="section-title">
        Comprehensive Solutions to <span class="gradient-text--blue">Power Your Business</span>
      </h2>
      <p class="section-subtitle">
        From concept to deployment, we deliver end-to-end technology solutions tailored to your unique business needs.
      </p>
    </div>

    <div class="features__grid">
      <%
        const services = [
          { icon: "cpu",           title: "AI-Powered Systems",       color: "#FF9F43", desc: "Intelligent enterprise solutions with machine learning integration, predictive analytics, and smart automation that transform how your business operates." },
          { icon: "code-2",        title: "Custom Software",          color: "#3B5BFF", desc: "Bespoke software applications built from the ground up to solve your specific challenges — scalable, secure, and designed for long-term success." },
          { icon: "smartphone",    title: "Mobile & Desktop Apps",    color: "#FF9F43", desc: "Native and cross-platform applications for iOS, Android, Windows, and macOS — delivering seamless user experiences across all devices." },
          { icon: "graduation-cap",title: "E-Learning Platforms",     color: "#3B5BFF", desc: "Complete learning management systems with interactive content delivery, progress tracking, assessments, and certification management." },
          { icon: "workflow",      title: "Automation Solutions",     color: "#FF9F43", desc: "Streamline operations with intelligent workflow automation — from attendance systems to inventory management and business process optimization." },
          { icon: "globe",         title: "Web Development",          color: "#3B5BFF", desc: "Modern, responsive websites and web applications built with cutting-edge technologies — fast, secure, and optimized for performance." }
        ];
      %>

      <% services.forEach(function(s, i) { %>
        <div class="feature-card anim-fade-up" data-delay="<%= i * 100 %>" data-color="<%= s.color %>">
          <div class="feature-card__icon" style="background: <%= s.color %>18; border: 1px solid <%= s.color %>30;">
            <i data-lucide="<%= s.icon %>" style="color: <%= s.color %>;"></i>
          </div>
          <h3 class="feature-card__title"><%= s.title %></h3>
          <p class="feature-card__desc"><%= s.desc %></p>
          <div class="feature-card__glow" style="background: radial-gradient(circle at top right, <%= s.color %>20, transparent 70%);"></div>
        </div>
      <% }); %>
    </div>

  </div>
</section>


<!-- ============================================================
     PORTFOLIO SECTION
     ============================================================ -->
<section id="portfolio" class="pf2">

  <!-- Background grid -->
  <div class="pf2__grid-bg" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="pf2-grid" width="72" height="72" patternUnits="userSpaceOnUse">
          <path d="M 72 0 L 0 0 0 72" fill="none" stroke="white" stroke-width="0.8"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#pf2-grid)"/>
    </svg>
  </div>

  <div class="pf2__container">

    <%
      const pf2GlobalStats = [
        { value: "7+",    label: "Projects Delivered" },
        { value: "100%",  label: "Client Satisfaction" },
        { value: "4+",    label: "Years Experience" },
        { value: "12+",   label: "Tech Stacks" }
      ];

      var pf2Projects =
        typeof portfolioProjects !== 'undefined' && portfolioProjects && portfolioProjects.length
          ? portfolioProjects
          : [];
    %>

    <!-- ── HEADER ── -->
    <div class="pf2__header">
      <div class="pf2__header-inner">

        <!-- Left heading -->
        <div class="pf2__heading-block">
          <div class="pf2__eyebrow pf2-anim pf2-anim--eyebrow">
            <i data-lucide="sparkles" class="pf2__eyebrow-icon"></i>
            <span>Selected Work</span>
          </div>

          <h2 class="pf2__title pf2-anim pf2-anim--title">
            Projects that<br/>
            <span class="pf2__title-gradient">speak results.</span>
          </h2>

          <p class="pf2__subtitle pf2-anim pf2-anim--subtitle">
            Each engagement is a strategic partnership — crafted with precision, built to scale, and measured by outcomes that matter.
          </p>
        </div>

        <!-- Right stats -->
        <div class="pf2__stats-grid">
          <% pf2GlobalStats.forEach(function(s, si) { %>
            <div class="pf2__stat-box pf2-anim pf2-anim--stat" data-pf2-delay="<%= 300 + si * 80 %>">
              <span class="pf2__stat-value pf2-counter" data-value="<%= s.value %>"><%= s.value %></span>
              <span class="pf2__stat-label"><%= s.label %></span>
            </div>
          <% }); %>
        </div>

      </div>

      <!-- Divider -->
      <div class="pf2__divider pf2-anim pf2-anim--divider"></div>
    </div>

    <!-- ── PROJECT CARDS ── -->
    <div class="pf2__cards">

      <% if (!pf2Projects.length) { %>
        <p style="grid-column:1/-1;text-align:center;color:rgba(255,255,255,0.45);padding:3rem 1rem;font-size:0.95rem;">
          No published projects yet. Run <code style="color:#ff8949;">npm run seed</code> or add projects in <a href="/admin" style="color:#7c9bff;">/admin</a>.
        </p>
      <% } %>

      <% pf2Projects.forEach(function(p, i) { %>
        <div class="pf2-card pf2-card--anim <%= p.flip ? 'pf2-card--flip' : '' %>"
             data-pf2-card-idx="<%= i %>"
             style="--accent: <%= p.accent %>; --glow: <%= p.glow %>; --dim: <%= p.dim %>;">

          <!-- Glow blob -->
          <div class="pf2-card__blob" style="background: radial-gradient(circle, <%= p.glow %> 0%, transparent 70%);"></div>

          <div class="pf2-card__inner">

            <!-- Image side -->
            <div class="pf2-card__img-side">
              <% if (p.image) { %>
              <img src="<%= p.image %>" alt="<%= p.title %>" class="pf2-card__img" loading="lazy"/>
              <% } else { %>
              <div class="pf2-card__img pf2-card__img-placeholder" aria-hidden="true"></div>
              <% } %>

              <!-- Gradient overlay -->
              <div class="pf2-card__img-overlay <%= p.flip ? 'pf2-card__img-overlay--flip' : '' %>"></div>
              <div class="pf2-card__img-overlay-mobile"></div>

              <!-- Floating index watermark -->
              <div class="pf2-card__index" style="color: <%= p.accent %>; <%= p.flip ? 'left:16px;right:auto;' : 'right:16px;left:auto;' %>">
                <%= p.index %>
              </div>

              <!-- Year badge -->
              <div class="pf2-card__year-badge pf2-card__year-badge--anim"><%= p.year %></div>
            </div>

            <!-- Content side -->
            <div class="pf2-card__content">

              <!-- Category -->
              <div class="pf2-card__category pf2-card__row--anim" data-row-delay="0">
                <span class="pf2-card__category-line" style="background: <%= p.accent %>;"></span>
                <span class="pf2-card__category-text" style="color: <%= p.accent %>;"><%= p.category %></span>
              </div>

              <!-- Title -->
              <h3 class="pf2-card__title pf2-card__row--anim" data-row-delay="60"><%= p.title %></h3>

              <!-- Description -->
              <p class="pf2-card__desc pf2-card__row--anim" data-row-delay="120"><%= p.description %></p>

              <!-- Metrics -->
              <div class="pf2-card__metrics pf2-card__row--anim" data-row-delay="180">
                <% p.metrics.forEach(function(m) { %>
                  <div class="pf2-card__metric">
                    <span class="pf2-card__metric-value" style="color: <%= p.accent %>;"><%= m.v %></span>
                    <span class="pf2-card__metric-label"><%= m.l %></span>
                  </div>
                <% }); %>
              </div>

              <!-- Tags -->
              <div class="pf2-card__tags pf2-card__row--anim" data-row-delay="240">
                <% p.tags.forEach(function(tag, ti) { %>
                  <span class="pf2-card__tag pf2-card__tag--anim" data-tag-delay="<%= ti * 50 %>"
                        style="background: <%= p.dim %>; color: <%= p.accent %>; border-color: <%= p.accent %>28;">
                    <%= tag %>
                  </span>
                <% }); %>
              </div>

              <!-- CTA button -->
              <a href="/case-study/<%= p.id %>" class="pf2-card__btn pf2-card__row--anim" data-row-delay="340"
                 style="border-color: <%= p.accent %>55; color: <%= p.accent %>;">
                View Case Study
                <i data-lucide="arrow-up-right" class="pf2-card__btn-icon"></i>
              </a>

            </div>

          </div><!-- /.pf2-card__inner -->
        </div>
      <% }); %>

    </div>

    <!-- ── BOTTOM CTA ── -->
    <div class="pf2__cta pf2-anim pf2-anim--cta">
      <div class="pf2__cta-glow" aria-hidden="true"></div>
      <p class="pf2__cta-eyebrow">Ready to build?</p>
      <h3 class="pf2__cta-title">Have a project in mind?</h3>
      <p class="pf2__cta-sub">
        Let's turn your vision into a product that performs. We handle strategy, design, and engineering.
      </p>
      <div class="pf2__cta-btns">
        <a href="#contact" class="btn btn--primary btn--lg pf2__cta-primary">
          Start a Project
          <i data-lucide="arrow-right"></i>
        </a>
      </div>
    </div>

  </div>
</section>


<!-- ============================================================
     OUR PROCESS SECTION
     ============================================================ -->
<section id="how-it-works" class="how-it-works">
  <div class="how-it-works__container">

    <div class="how-it-works__header anim-fade-up">
      <span class="badge badge--orange">Our Process</span>
      <h2 class="section-title">
        From Vision to Reality in <span class="gradient-text--orange">Five Phases</span>
      </h2>
      <p class="section-subtitle">
        A structured, transparent process — so you always know where your project stands.
      </p>
    </div>

    <div class="process-timeline">
      <div class="process-spine"></div>

      <%
        const steps = [
          { num: "01", icon: "search",     color: "#3B5BFF", title: "Discovery & Analysis",  desc: "We audit your business requirements, map existing workflows, and surface opportunities for innovation and optimization." },
          { num: "02", icon: "pen-tool",   color: "#FF9F43", title: "Design & Architecture", desc: "Detailed blueprints, wireframes, and system architecture ensure every layer of the solution aligns with your objectives." },
          { num: "03", icon: "code-2",     color: "#3B5BFF", title: "Development & Testing", desc: "Agile sprints with continuous integration, automated testing, and demos keep you in control at every milestone." },
          { num: "04", icon: "rocket",     color: "#FF9F43", title: "Launch & Deployment",   desc: "Zero-downtime production rollout with complete handover documentation and a dedicated go-live support window." },
          { num: "05", icon: "refresh-cw", color: "#3B5BFF", title: "Maintenance & Updates", desc: "Ongoing monitoring, proactive updates, performance tuning, and feature enhancements — keeping your product ahead of the curve." }
        ];
      %>

      <% steps.forEach(function(s, i) { %>
        <% const side = i % 2 === 0 ? 'left' : 'right'; %>
        <div class="tl-item tl-item--<%= side %> tl-slide-<%= side %>" data-delay="<%= i * 160 %>">

          <!-- Content side -->
          <div class="tl-content">
            <div class="tl-phase-label" style="color: <%= s.color %>;">
              <i data-lucide="<%= s.icon %>" class="tl-phase-icon"></i>
              <span>Phase <%= s.num %></span>
            </div>
            <h3 class="tl-title"><%= s.title %></h3>
            <p class="tl-desc"><%= s.desc %></p>
            <div class="tl-underline" style="background: linear-gradient(90deg, <%= s.color %>, transparent);"></div>
          </div>

          <!-- Spacer (opposite side) -->
          <div class="tl-spacer"></div>

          <!-- Central node -->
          <div class="tl-node" style="--c: <%= s.color %>; background: <%= s.color %>; box-shadow: 0 0 0 6px <%= s.color %>25, 0 0 28px <%= s.color %>50;">
            <i data-lucide="<%= s.icon %>" class="tl-node__icon"></i>
          </div>

        </div>
      <% }); %>
    </div>

  </div>
</section>


<!-- ============================================================
     WHY CHOOSE US SECTION
     ============================================================ -->
