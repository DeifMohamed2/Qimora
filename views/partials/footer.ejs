<!-- ============================================================
     FOOTER — hero-style background, brand + newsletter + bottom bar
     ============================================================ -->
<footer class="footer" id="site-footer">

  <!-- Match hero / contact atmosphere -->
  <div class="hero__glow hero__glow--top" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--bottom" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--center" aria-hidden="true"></div>
  <div class="hero__grid-overlay" aria-hidden="true"></div>

  <div class="footer__container">

    <div class="footer__main">
      <div class="footer__brand anim-fade-up">
        <a href="/" class="footer__logo">
          <img
            src="/images/qimora.png"
            alt="Qimora"
            class="footer__logo-img"
            width="1920"
            height="578"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="footer__tagline">
          Building the future with intelligent systems.<br />
          Enterprise solutions, crafted with excellence.
        </p>

        <div class="footer__socials" aria-label="Social media">
          <a href="#" class="footer__social-btn" data-color="#94A3B8" aria-label="GitHub" title="GitHub">
            <i class="fa-brands fa-github" aria-hidden="true"></i>
          </a>
          <a href="#" class="footer__social-btn" data-color="#3B5BFF" aria-label="LinkedIn" title="LinkedIn">
            <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
          </a>
          <a href="#" class="footer__social-btn" data-color="#FF9F43" aria-label="YouTube" title="YouTube">
            <i class="fa-brands fa-youtube" aria-hidden="true"></i>
          </a>
        </div>
      </div>

      <div class="footer__newsletter-wrap anim-fade-up" data-delay="120">
        <div class="footer__newsletter">
          <h3 class="footer__newsletter-title">Stay in the loop</h3>
          <p class="footer__newsletter-desc">Get product updates, engineering insights, and launch news. No spam, ever.</p>
          <form class="footer__newsletter-form" onsubmit="return false;">
            <div class="footer__newsletter-input-wrap">
              <i data-lucide="mail" class="footer__newsletter-icon"></i>
              <input type="email" placeholder="you@company.com" class="footer__newsletter-input" autocomplete="email" />
            </div>
            <button type="submit" class="footer__newsletter-btn">
              Subscribe
              <i data-lucide="arrow-right"></i>
            </button>
          </form>
          <p class="footer__newsletter-note">
            <i data-lucide="shield-check" class="footer__newsletter-note-icon"></i>
            We respect your privacy. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </div>

    <div class="footer__divider"></div>

    <div class="footer__bottom">
      <div class="footer__bottom-left">
        <span class="footer__copyright">&copy; 2026 Qimora, Inc. All rights reserved.</span>
      </div>
      <div class="footer__bottom-center">
        <div class="footer__status">
          <span class="footer__status-dot"></span>
          <span>All systems operational</span>
        </div>
      </div>
      <div class="footer__bottom-right">
        <a href="#" class="footer__bottom-link">Privacy</a>
        <span class="footer__bottom-sep">&middot;</span>
        <a href="#" class="footer__bottom-link">Terms</a>
        <span class="footer__bottom-sep">&middot;</span>
        <a href="#" class="footer__bottom-link">Cookies</a>
      </div>
    </div>

  </div>

  <div class="footer__bg-glow"></div>
</footer>
