<nav id="navbar" class="navbar">
  <div class="navbar__container">
    <div class="navbar__inner">

      <!-- Brand icon -->
      <a href="/" class="navbar__logo" id="navbar-logo">
        <img src="/images/icon.svg" alt="Qimora" class="navbar__logo-img" width="108" height="109" />
      </a>

      <!-- Desktop Nav — Floating pill -->
      <div class="navbar__center-pill">
        <button class="navbar__link" data-scroll="product">
          <i data-lucide="home" class="navbar__link-icon"></i>
