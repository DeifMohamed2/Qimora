<% if (typeof flash !== 'undefined' && flash && flash.msg) { %>
  <div
    class="admin-flash admin-flash--<%= flash.type === 'err' ? 'err' : 'ok' %> flash-dismissible"
    role="alert"
    data-autoclose-ms="6000"
  >
    <div class="admin-flash__row">
      <% if (flash.type === 'err') { %>
        <svg class="admin-flash__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <% } else { %>
        <svg class="admin-flash__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      <% } %>
      <span class="admin-flash__text"><%= flash.msg %></span>
    </div>
    <button type="button" class="admin-flash__close" data-flash-close aria-label="Dismiss alert">&times;</button>
  </div>
<% } %>
