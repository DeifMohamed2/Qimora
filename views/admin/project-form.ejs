<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/images/icon.svg" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-body">
<div class="admin-app">

  <% var currentPage = 'projects'; %>
  <%- include('partials/sidebar') %>

  <div class="admin-main">

    <!-- Top bar -->
    <header class="admin-topbar">
      <div class="admin-topbar__left">
        <button class="a-btn a-btn--ghost a-btn--sm" id="sidebar-toggle" aria-label="Toggle sidebar" style="display:none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <nav class="admin-topbar__breadcrumb">
          <a href="/admin">Admin</a>
          <span class="admin-topbar__sep">/</span>
          <a href="/admin">Projects</a>
          <span class="admin-topbar__sep">/</span>
          <span><%= isEdit ? project.title : 'New project' %></span>
        </nav>
      </div>
    </header>

    <!-- Content -->
    <div class="admin-content">

      <% if (error) { %>
        <div class="admin-error">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <%= error %>
        </div>
      <% } %>

      <div class="admin-page-header">
        <div>
          <h1><%= isEdit ? 'Edit project' : 'New project' %></h1>
          <p><%= isEdit ? "Update this project's details, media and case study content." : "Fill in the details below to publish a new project and case study." %></p>
          <p style="margin-top:10px;"><a href="/admin" style="font-size:0.85rem;font-weight:600;color:var(--a-muted2);">← Back to all projects</a></p>
        </div>
      </div>

      <form
        method="post"
        action="<%= isEdit ? '/admin/projects/' + project._id : '/admin/projects' %>"
        enctype="multipart/form-data"
        id="project-form"
      >
      <%
        var pcats = typeof projectCategories !== 'undefined' && projectCategories ? projectCategories : [];
        var licons = typeof lucideIconOptions !== 'undefined' && lucideIconOptions ? lucideIconOptions : [];
        var curIcon = (project.icon && String(project.icon).trim()) ? String(project.icon).trim() : 'layers';
        var defaultAccent = '#3B5BFF';
        var rawColor = (project.color && String(project.color).trim()) ? String(project.color).trim() : '';
        var validHex = /^#[0-9A-Fa-f]{6}$/i.test(rawColor);
        var pickVal = validHex ? rawColor : defaultAccent;
        var showColor = validHex ? rawColor : defaultAccent;
        var techOpts = typeof technologyOptions !== 'undefined' && technologyOptions ? technologyOptions : [];
        var techArr = project.technologies || [];
        var knownTechSet = {};
        techOpts.forEach(function (t) { knownTechSet[String(t).trim().toLowerCase()] = true; });
        var techOther = techArr.filter(function (t) {
          return !knownTechSet[String(t).trim().toLowerCase()];
        });
        var durOpts = typeof durationOptions !== 'undefined' && durationOptions ? durationOptions : [];
        var teamSzOpts = typeof teamSizeOptions !== 'undefined' && teamSizeOptions ? teamSizeOptions : [];
        var curDur = (project.duration && String(project.duration).trim()) || '';
        var curTeam = (project.teamSize && String(project.teamSize).trim()) || '';
      %>

        <!-- Tabs -->
        <div class="a-tabs" role="tablist">
          <button type="button" class="a-tab active" data-panel="p-details" role="tab">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;margin-right:5px;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            Details & media
          </button>
          <button type="button" class="a-tab" data-panel="p-case" role="tab">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;margin-right:5px;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Case study
          </button>
          <button type="button" class="a-tab" data-panel="p-results" role="tab">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;margin-right:5px;"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Results & testimonial
          </button>
        </div>

        <!-- ═══ PANEL 1 — Details & media ══════════════════════ -->
        <div id="p-details" class="a-panel active">

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">Basic info</span>
            </div>
            <div class="admin-section__body">
              <div class="admin-form-cols admin-form-cols--wide">
                <div class="a-field">
                  <label for="title">Title *</label>
                  <input type="text" id="title" name="title" value="<%= project.title %>" required placeholder="E.g. Healthcare Platform" />
                </div>
                <div class="a-field">
                  <label for="slug">Slug (auto-generated if empty)</label>
                  <input type="text" id="slug" name="slug" value="<%= project.slug %>" placeholder="e.g. healthcare-platform" />
                </div>
                <div class="a-field">
                  <label for="categoryPreset">Category</label>
                  <select id="categoryPreset" aria-label="Pick a category preset">
                    <option value="">— Quick pick or type below —</option>
                    <% pcats.forEach(function (c) { %>
                    <option value="<%= c %>"><%= c %></option>
                    <% }); %>
                  </select>
                  <input type="text" id="category" name="category" value="<%= project.category %>" placeholder="e.g. Healthcare Solution" />
                  <span class="a-help">Select a preset or type your own label; the text field is saved.</span>
                </div>
                <div class="a-field">
                  <label for="cardYear">Year (portfolio card badge)</label>
                  <input type="text" id="cardYear" name="cardYear" value="<%= project.cardYear %>" placeholder="2024" />
                </div>
                <div class="a-field admin-col-full">
                  <label for="description">Short description (portfolio card)</label>
                  <textarea id="description" name="description" rows="3" placeholder="One or two sentences shown on the portfolio card."><%= project.description %></textarea>
                </div>
              </div>
            </div>
          </div>

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">Visual identity</span>
            </div>
            <div class="admin-section__body">
              <div class="admin-form-cols admin-form-cols--wide">
                <div class="a-field admin-col-full">
                  <label>Accent color</label>
                  <p class="a-color-presets-intro">Recommended swatches use the <strong>site palette</strong> (light / dark) and <code>color-mix</code> relatives—tweak the hex field for anything custom.</p>
                  <div class="a-color-presets" role="group" aria-label="Recommended accent colors from design tokens">
                    <div class="a-color-presets__row">
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-blue-light" title="Light theme primary blue" aria-label="Light primary blue"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-blue-light);"></span></button>
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-blue-dark" title="Dark theme primary blue" aria-label="Dark primary blue"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-blue-dark);"></span></button>
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-orange" title="Accent orange" aria-label="Accent orange"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-orange);"></span></button>
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-blue-soft" title="Soft blue (mix)" aria-label="Soft blue mix"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-blue-soft);"></span></button>
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-blue-deep" title="Deep blue (mix)" aria-label="Deep blue mix"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-blue-deep);"></span></button>
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-orange-deep" title="Warm orange–navy (mix)" aria-label="Warm orange navy mix"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-orange-deep);"></span></button>
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-muted-blue" title="Muted blue (mix)" aria-label="Muted blue mix"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-muted-blue);"></span></button>
                      <button type="button" class="a-color-preset" data-qvar="--q-accent-preset-surface-tint" title="Section surface tint (mix)" aria-label="Surface tint mix"><span class="a-color-preset__dot" style="background: var(--q-accent-preset-surface-tint);"></span></button>
                    </div>
                  </div>
                  <div class="a-color-row">
                    <input type="color" id="colorPick" value="<%= pickVal %>" aria-label="Colour picker" />
                    <input type="text" id="color" name="color" value="<%= validHex ? rawColor : defaultAccent %>" placeholder="#3B5BFF" pattern="^#[0-9A-Fa-f]{6}$" style="flex:1;" />
                    <div class="a-color-swatch" id="colorSwatch" style="background:<%= showColor %>;flex:none;width:42px;"></div>
                  </div>
                  <span class="a-help">Used on the portfolio card and case study. Tokens mirror the public site light/dark themes.</span>
                </div>
                <div class="a-field">
                  <label for="iconPreset">Lucide icon</label>
                  <select id="iconPreset" aria-label="Pick a Lucide icon preset">
                    <option value="">— Quick pick or type slug below —</option>
                    <% licons.forEach(function (o) { %>
                    <option value="<%= o.value %>"><%= o.label %></option>
                    <% }); %>
                  </select>
                  <input type="text" id="icon" name="icon" value="<%= curIcon %>" placeholder="e.g. layers, building-2" spellcheck="false" autocapitalize="off" />
                  <span class="a-help">Presets match <a href="https://lucide.dev/icons/" target="_blank" rel="noopener">lucide.dev</a> slugs; any valid icon name works.</span>
                </div>
                <div class="a-field">
                  <label for="image">Poster image URL</label>
                  <input type="text" id="image" name="image" value="<%= project.image %>" placeholder="https://… or /uploads/projects/…" spellcheck="false" autocapitalize="off" />
                  <span class="a-help">Full URL or a site path starting with <code>/</code> (uploaded posters fill this automatically). This image is used on the admin card and the home portfolio.</span>
                  <% if (isEdit && project.image) {
                    var imgPrev = String(project.image);
                    var imgShort = imgPrev.length > 72 ? imgPrev.slice(0, 72) + '…' : imgPrev;
                  %><span class="a-help">Saved value: <code style="word-break:break-all;"><%= imgShort %></code></span><% } %>
                </div>
                <div class="a-field">
                  <label for="poster">Upload poster (replaces URL)</label>
                  <input type="file" id="poster" name="poster" accept="image/*" />
                  <span class="a-help">Max 12 MB. Stored under <code>/uploads/projects/</code>. Use this field for the card / portfolio hero image (not the web carousel below).</span>
                  <% if (isEdit && project.image) { %>
                  <div style="margin-top:10px;">
                    <span class="a-help" style="display:block;margin-bottom:6px;">Preview of saved poster</span>
                    <img src="<%= project.image %>" alt="" style="max-width:220px;max-height:132px;border-radius:10px;border:1px solid var(--a-border, rgba(255,255,255,0.12));object-fit:cover;" loading="lazy" onerror="this.style.display='none'" />
                  </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">Project metadata</span>
            </div>
            <div class="admin-section__body">
              <div class="admin-form-cols">
                <div class="a-field">
                  <label for="industry">Industry</label>
                  <input type="text" id="industry" name="industry" value="<%= project.industry %>" placeholder="e.g. Healthcare" />
                </div>
                <div class="a-field">
                  <label for="duration">Duration</label>
                  <select id="duration" name="duration" aria-label="Project duration">
                    <option value="">— Select duration —</option>
                    <% durOpts.forEach(function (d) { %>
                    <option value="<%= d %>" <%= curDur === d ? 'selected' : '' %>><%= d %></option>
                    <% }); %>
                    <% if (curDur && durOpts.indexOf(curDur) === -1) { %>
                    <option value="<%= curDur %>" selected><%= curDur %> (saved)</option>
                    <% } %>
                  </select>
                  <span class="a-help">Pick a preset; legacy custom text still saves as its own option.</span>
                </div>
                <div class="a-field">
                  <label for="teamSize">Team size</label>
                  <select id="teamSize" name="teamSize" aria-label="Team size">
                    <option value="">— Select team size —</option>
                    <% teamSzOpts.forEach(function (s) { %>
                    <option value="<%= s %>" <%= curTeam === s ? 'selected' : '' %>><%= s %></option>
                    <% }); %>
                    <% if (curTeam && teamSzOpts.indexOf(curTeam) === -1) { %>
                    <option value="<%= curTeam %>" selected><%= curTeam %> (saved)</option>
                    <% } %>
                  </select>
                  <span class="a-help">Choose the closest match; unusual values stay as a saved option.</span>
                </div>
                <div class="a-field">
                  <label for="platforms">Platforms</label>
                  <input type="text" id="platforms" name="platforms" value="<%= project.platforms %>" placeholder="e.g. Web, iOS, Android" />
                </div>
                <div class="a-field admin-col-full">
                  <label id="technologies-label">Technologies</label>
                  <div class="a-tech-multiselect" id="techMultiselect">
                    <button type="button" class="a-tech-multiselect__toggle" id="techToggle" aria-expanded="false" aria-haspopup="listbox" aria-controls="techPanel">
                      <span class="a-tech-multiselect__summary" id="techSummary">Select technologies…</span>
                      <svg class="a-tech-multiselect__chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="a-tech-multiselect__panel" id="techPanel" hidden>
                      <input type="search" class="a-tech-multiselect__search" id="techSearch" placeholder="Filter list…" autocomplete="off" />
                      <div class="a-tech-multiselect__list" role="listbox" aria-labelledby="technologies-label">
                        <% techOpts.forEach(function (name) {
                          var L = String(name).trim().toLowerCase();
                          var isOn = techArr.some(function (t) { return String(t).trim().toLowerCase() === L; });
                        %>
                        <label class="a-tech-multiselect__item">
                          <input type="checkbox" name="technologies" value="<%= name %>" <%= isOn ? 'checked' : '' %> />
                          <span><%= name %></span>
                        </label>
                        <% }); %>
                      </div>
                    </div>
                  </div>
                  <div style="margin-top:12px;">
                    <label for="technologiesOther" style="font-size:0.75rem;font-weight:700;color:var(--a-muted2);letter-spacing:0.02em;display:block;margin-bottom:5px;">Additional technologies</label>
                    <input type="text" id="technologiesOther" name="technologiesOther" value="<%= techOther.join(', ') %>" placeholder="Comma-separated — e.g. Solidity, Traefik, legacy SOAP…" />
                  </div>
                  <span class="a-help">Use the checklist for known stacks; add anything else below. Names are matched for icons when possible.</span>
                </div>
              </div>
            </div>
          </div>

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">Links & flags</span>
            </div>
            <div class="admin-section__body">
              <p class="a-section-lede">These control badges and outbound links on the portfolio card and case study. Turn on only what applies—URLs can stay empty until you have them.</p>
              <div class="admin-flag-grid">
                <div class="admin-flag-card">
                  <h3 class="admin-flag-card__title">Website</h3>
                  <div class="a-field a-field--row">
                    <input type="checkbox" id="hasWebsite" name="hasWebsite" value="true" <%= project.hasWebsite ? 'checked' : '' %> />
                    <label for="hasWebsite">Show “live site” / website link</label>
                  </div>
                  <div class="a-field">
                    <label for="websiteUrl">Website URL</label>
                    <input type="url" id="websiteUrl" name="websiteUrl" value="<%= project.websiteUrl %>" placeholder="https://example.com" />
                  </div>
                  <p class="a-help">Used for the primary external link when this option is enabled.</p>
                </div>

                <div class="admin-flag-card">
                  <h3 class="admin-flag-card__title">Mobile apps</h3>
                  <div class="a-field a-field--row">
                    <input type="checkbox" id="hasMobileApp" name="hasMobileApp" value="true" <%= project.hasMobileApp ? 'checked' : '' %> />
                    <label for="hasMobileApp">Show app store badges / mobile availability</label>
                  </div>
                  <div class="a-field">
                    <label for="appStoreUrl">App Store</label>
                    <input type="url" id="appStoreUrl" name="appStoreUrl" value="<%= project.appStoreUrl %>" placeholder="https://apps.apple.com/…" />
                  </div>
                  <div class="a-field">
                    <label for="playStoreUrl">Google Play</label>
                    <input type="url" id="playStoreUrl" name="playStoreUrl" value="<%= project.playStoreUrl %>" placeholder="https://play.google.com/…" />
                  </div>
                </div>

                <div class="admin-flag-card admin-flag-card--wide">
                  <h3 class="admin-flag-card__title">Case study presentation</h3>
                  <div class="admin-flag-grid admin-flag-grid--tight">
                    <div class="a-field a-field--row">
                      <input type="checkbox" id="hasAI" name="hasAI" value="true" <%= project.hasAI ? 'checked' : '' %> />
                      <label for="hasAI">Highlight as AI-powered</label>
                    </div>
                    <div class="a-field a-field--row">
                      <input type="checkbox" id="isEcosystem" name="isEcosystem" value="true" <%= project.isEcosystem ? 'checked' : '' %> />
                      <label for="isEcosystem">Ecosystem layout — Integrated Systems (Section&nbsp;02 modules)</label>
                    </div>
                  </div>
                  <p class="a-help">When enabled, the case study shows the <strong>Integrated Systems</strong> block after the key features section. Both sections are independent — you can have key features only, modules only, or both together.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">Screenshots & media</span>
            </div>
            <div class="admin-section__body">
              <p class="a-section-lede">Web images power the desktop carousel; mobile shots drive the phone mockup and captions on the case study. Uploads are stored under <code>/uploads/projects/</code>.</p>

              <div class="a-media-block">
                <h4 class="a-builder-section__title">Web carousel</h4>
                <p class="a-builder-section__hint">Shown beside the poster in the case study web viewer. Each slot shows a preview; use a full URL or a path like <code>/uploads/projects/…</code>. You can also upload files below (they append on save).</p>
                <div id="extraWebUrlBuilder" class="a-media-grid">
                  <% (project.extraImages || []).forEach(function (url) { %>
                  <div class="a-media-card a-media-card--web js-extra-url-row">
                    <div class="a-media-card__thumb a-media-card__thumb--web">
                      <img class="js-extra-thumb" src="<%= url %>" alt="" loading="lazy" decoding="async" onerror="this.hidden=true;var r=this.closest('.js-extra-url-row');if(r){r.classList.add('is-extra-thumb-broken');}" />
                    </div>
                    <label class="a-media-card__cap-label">Image URL or path</label>
                    <input type="text" class="js-extra-url" value="<%= url %>" placeholder="https://… or /uploads/…" spellcheck="false" autocapitalize="off" />
                    <button type="button" class="a-btn a-btn--ghost a-btn--sm a-media-card__remove js-extra-remove">Remove</button>
                  </div>
                  <% }); %>
                </div>
                <button type="button" class="a-btn a-btn--ghost a-builder-add" id="addExtraUrlRow">+ Add image URL</button>

                <div class="a-media-dropzone" id="extraWebDropzone" aria-label="Upload web carousel images">
                  <div class="a-media-dropzone__hit">
                    <input type="file" id="extraWebImages" name="extraWebImages" class="a-media-dropzone__file" accept="image/*" multiple />
                    <div class="a-media-dropzone__inner">
                      <svg class="a-media-dropzone__icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                      <span class="a-media-dropzone__title">Drop web images here</span>
                      <span class="a-media-dropzone__sub">or click to browse — files append on save</span>
                    </div>
                  </div>
                  <div id="extraWebPreviewStrip" class="a-media-strip" hidden></div>
                </div>
              </div>

              <div class="a-media-block a-builder-section--divider">
                <h4 class="a-builder-section__title">Mobile screenshots</h4>
                <p class="a-builder-section__hint">Each frame has its own caption on the case study. Edit captions below; remove a card to drop it on the next save. New uploads get one caption field per file.</p>
                <div id="mobileShotsBuilder" class="a-media-grid">
                  <% (project.mobileScreenshots || []).forEach(function (shot, i) { %>
                  <div class="a-media-card js-mobile-shot" data-url="<%= shot.url %>">
                    <div class="a-media-card__thumb">
                      <img src="<%= shot.url %>" alt="" loading="lazy" decoding="async" />
                    </div>
                    <label class="a-media-card__cap-label">Caption</label>
                    <input type="text" class="js-msc-caption" value="<%= shot.caption || '' %>" placeholder="e.g. Home, Dashboard" autocomplete="off" />
                    <button type="button" class="a-btn a-btn--ghost a-btn--sm a-media-card__remove js-msc-remove">Remove</button>
                  </div>
                  <% }); %>
                </div>

                <div class="a-media-dropzone a-media-dropzone--mobile" id="mobileScreensDropzone" aria-label="Upload mobile screenshots">
                  <div class="a-media-dropzone__hit">
                    <input type="file" id="screenshots" name="screenshots" class="a-media-dropzone__file" accept="image/*" multiple />
                    <div class="a-media-dropzone__inner">
                      <svg class="a-media-dropzone__icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                      <span class="a-media-dropzone__title">Add new mobile screenshots</span>
                      <span class="a-media-dropzone__sub">Portrait PNG/JPG — captions appear under each preview</span>
                    </div>
                  </div>
                  <div id="mobileNewPreviewGrid" class="a-media-new-grid"></div>
                </div>
              </div>

              <textarea id="extraImagesJson" name="extraImagesJson" class="a-json-hidden" aria-hidden="true"><%- JSON.stringify(project.extraImages || []) %></textarea>
              <textarea id="mobileScreenshotsJson" name="mobileScreenshotsJson" class="a-json-hidden" aria-hidden="true"><%- JSON.stringify(project.mobileScreenshots || []) %></textarea>
            </div>
          </div>

          <template id="tpl-extra-url-row">
            <div class="a-media-card a-media-card--web js-extra-url-row is-extra-url-empty">
              <div class="a-media-card__thumb a-media-card__thumb--web">
                <img class="js-extra-thumb" alt="" decoding="async" hidden />
              </div>
              <label class="a-media-card__cap-label">Image URL or path</label>
              <input type="text" class="js-extra-url" placeholder="https://… or /uploads/…" spellcheck="false" autocapitalize="off" />
              <button type="button" class="a-btn a-btn--ghost a-btn--sm a-media-card__remove js-extra-remove">Remove</button>
            </div>
          </template>

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">Publishing</span>
            </div>
            <div class="admin-section__body">
              <div class="admin-form-cols">
                <div class="a-field">
                  <label for="order">Sort order (lower = first)</label>
                  <input type="number" id="order" name="order" value="<%= project.order %>" step="1" min="0" />
                </div>
                <div class="a-field a-field--row" style="align-self:flex-end;padding-bottom:4px;">
                  <input type="checkbox" id="isPublished" name="isPublished" value="true" <%= project.isPublished !== false ? 'checked' : '' %> />
                  <label for="isPublished">Published — visible on site</label>
                </div>
              </div>
            </div>
          </div>

        </div><!-- /p-details -->

        <!-- ═══ PANEL 2 — Case study content ══════════════════ -->
        <div id="p-case" class="a-panel">

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">01 — Project overview</span>
            </div>
            <div class="admin-section__body">
              <div class="admin-form-cols admin-form-cols--wide">
                <div class="a-field admin-col-full">
                  <label for="overview">What we built & why</label>
                  <textarea id="overview" name="overview" rows="7" placeholder="Describe the product, client context, and goals…"><%= project.overview %></textarea>
                </div>
                <div class="a-field admin-col-full">
                  <label for="challenge">The challenge</label>
                  <textarea id="challenge" name="challenge" rows="5" placeholder="What problem were you solving? What constraints existed?"><%= project.challenge %></textarea>
                </div>
                <div class="a-field admin-col-full">
                  <label for="techRationale">Tech stack & selection rationale</label>
                  <textarea id="techRationale" name="techRationale" rows="4" placeholder="Why did you choose these technologies?"><%= project.techRationale %></textarea>
                </div>
              </div>
            </div>
          </div>

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">02 — Key features</span>
            </div>
            <div class="admin-section__body">
              <p class="a-section-lede">These feature cards always appear on the case study when you add at least one block. They show <strong>alongside</strong> the Integrated Systems modules when both have content.</p>

              <div class="a-builder-section">
                <h4 class="a-builder-section__title">Detailed features — “Built to Perform”</h4>
                <p class="a-builder-section__hint">Each block needs a <strong>Lucide</strong> icon slug (see <a href="https://lucide.dev/icons/" target="_blank" rel="noopener">lucide.dev</a>), a title, and a short description. These render as the "Built to Perform" card grid. They appear alongside the Integrated Systems modules if you fill both.</p>
                <div id="fullFeaturesBuilder" class="a-builder-stack">
                  <% (project.fullFeatures || []).forEach(function (row, idx) { %>
                  <div class="a-builder-card js-ff-row">
                    <div class="a-builder-card__toolbar">
                      <span class="a-builder-card__label">Feature <%= idx + 1 %></span>
                      <button type="button" class="a-btn a-btn--ghost a-btn--sm js-ff-remove">Remove</button>
                    </div>
                    <div class="admin-form-cols admin-form-cols--wide">
                      <div class="a-field">
                        <label>Lucide icon</label>
                        <input type="text" class="js-ff-icon" value="<%= row.icon || '' %>" placeholder="e.g. sparkles, shield-check" autocomplete="off" spellcheck="false" />
                      </div>
                      <div class="a-field admin-col-full">
                        <label>Title</label>
                        <input type="text" class="js-ff-title" value="<%= row.title || '' %>" placeholder="Feature headline" />
                      </div>
                      <div class="a-field admin-col-full">
                        <label>Description</label>
                        <textarea class="js-ff-desc" rows="3" placeholder="What this feature does for users…"><%= row.desc || '' %></textarea>
                      </div>
                    </div>
                  </div>
                  <% }); %>
                </div>
                <button type="button" class="a-btn a-btn--ghost a-builder-add" id="addFullFeature">+ Add feature block</button>
              </div>

              <div class="a-builder-section a-builder-section--divider">
                <h4 class="a-builder-section__title">Simple feature labels (fallback)</h4>
                <p class="a-builder-section__hint">If you leave <strong>detailed features</strong> empty above, the case study can show these short titles as simple cards with a default icon. Optional when you already use detailed blocks.</p>
                <div id="simpleFeaturesBuilder" class="a-builder-stack">
                  <% (project.features || []).forEach(function (label) { %>
                  <div class="a-builder-row js-sf-row">
                    <input type="text" class="js-sf-label" value="<%= label %>" placeholder="Short label, e.g. Real-time sync" />
                    <button type="button" class="a-btn a-btn--ghost a-btn--sm js-sf-remove" aria-label="Remove row">×</button>
                  </div>
                  <% }); %>
                </div>
                <button type="button" class="a-btn a-btn--ghost a-builder-add" id="addSimpleFeature">+ Add label</button>
              </div>

              <textarea id="fullFeaturesJson" name="fullFeaturesJson" class="a-json-hidden" aria-hidden="true"><%- JSON.stringify(project.fullFeatures || []) %></textarea>
              <textarea id="featuresJson" name="featuresJson" class="a-json-hidden" aria-hidden="true"><%- JSON.stringify(project.features || []) %></textarea>
            </div>
          </div>

          <div class="admin-section admin-section--ecosystem">
            <div class="admin-section__head">
              <span class="admin-section__title">Integrated Systems — Section 02</span>
              <span class="admin-section__badge" id="ecosystemBadge">Off</span>
            </div>
            <div class="admin-section__body">
              <div id="ecosystemSectionWrap" class="admin-ecosystem-wrap">
                <div class="admin-ecosystem-banner" id="ecosystemInactiveBanner" role="status">
                  Turn on <strong>Ecosystem layout</strong> under Links &amp; flags to publish this block on the case study. You can still edit modules below anytime.
                </div>

                <p class="a-section-lede">This block renders <strong>after</strong> the key features section when ecosystem layout is on and at least one module exists. Add both key features and modules and both will appear on the case study.</p>

                <div class="admin-form-cols admin-form-cols--wide">
                  <div class="a-field">
                    <label for="ecosystemSectionLabel">Pill label (beside “02”)</label>
                    <input type="text" id="ecosystemSectionLabel" name="ecosystemSectionLabel" value="<%= project.ecosystemSectionLabel != null ? project.ecosystemSectionLabel : '' %>" placeholder="Integrated Systems" />
                  </div>
                  <div class="a-field admin-col-full">
                    <label for="ecosystemTitle">Section title</label>
                    <input type="text" id="ecosystemTitle" name="ecosystemTitle" value="<%= project.ecosystemTitle != null ? project.ecosystemTitle : '' %>" placeholder="A Complete Ecosystem" />
                  </div>
                  <div class="a-field admin-col-full">
                    <label for="ecosystemSubtitle">Subtitle</label>
                    <textarea id="ecosystemSubtitle" name="ecosystemSubtitle" rows="2" placeholder="A suite of tightly integrated modules…"><%= project.ecosystemSubtitle != null ? project.ecosystemSubtitle : '' %></textarea>
                  </div>
                </div>

                <div class="a-builder-section a-builder-section--divider">
                  <h4 class="a-builder-section__title">Modules / integrations</h4>
                  <p class="a-builder-section__hint">Each module becomes a numbered card: name, Lucide icon, summary, longer description, and bullet features (one per line).</p>
                  <div id="subProjectsBuilder" class="a-builder-stack">
                  <% (project.subProjects || []).forEach(function (sp, idx) { %>
                  <div class="a-builder-card js-sp-card">
                    <div class="a-builder-card__toolbar">
                      <span class="a-builder-card__label">Module <%= idx + 1 %></span>
                      <button type="button" class="a-btn a-btn--ghost a-btn--sm js-sp-remove">Remove</button>
                    </div>
                    <div class="admin-form-cols admin-form-cols--wide">
                      <div class="a-field">
                        <label>Name</label>
                        <input type="text" class="js-sp-name" value="<%= sp.name || '' %>" placeholder="e.g. HR &amp; Attendance System" />
                      </div>
                      <div class="a-field">
                        <label>Lucide icon</label>
                        <input type="text" class="js-sp-icon" value="<%= sp.icon || '' %>" placeholder="layers" autocomplete="off" spellcheck="false" />
                      </div>
                      <div class="a-field admin-col-full">
                        <label>Short summary</label>
                        <input type="text" class="js-sp-desc" value="<%= sp.desc || '' %>" placeholder="One line under the title" />
                      </div>
                      <div class="a-field admin-col-full">
                        <label>Full description</label>
                        <textarea class="js-sp-fulldesc" rows="3" placeholder="Paragraph shown in the module card"><%= sp.fullDesc || '' %></textarea>
                      </div>
                      <div class="a-field admin-col-full">
                        <label>Bullet features (one per line)</label>
                        <textarea class="js-sp-features" rows="5" placeholder="First capability&#10;Second capability"><%= (sp.features || []).join('\n') %></textarea>
                      </div>
                    </div>
                  </div>
                  <% }); %>
                  </div>
                  <button type="button" class="a-btn a-btn--ghost a-builder-add" id="addSubProject">+ Add module</button>
                </div>

                <textarea id="subProjectsJson" name="subProjectsJson" class="a-json-hidden" aria-hidden="true"><%- JSON.stringify(project.subProjects || []) %></textarea>
              </div>
            </div>
          </div>

          <template id="tpl-full-feature">
            <div class="a-builder-card js-ff-row">
              <div class="a-builder-card__toolbar">
                <span class="a-builder-card__label">Feature</span>
                <button type="button" class="a-btn a-btn--ghost a-btn--sm js-ff-remove">Remove</button>
              </div>
              <div class="admin-form-cols admin-form-cols--wide">
                <div class="a-field">
                  <label>Lucide icon</label>
                  <input type="text" class="js-ff-icon" placeholder="e.g. sparkles" autocomplete="off" spellcheck="false" />
                </div>
                <div class="a-field admin-col-full">
                  <label>Title</label>
                  <input type="text" class="js-ff-title" placeholder="Feature headline" />
                </div>
                <div class="a-field admin-col-full">
                  <label>Description</label>
                  <textarea class="js-ff-desc" rows="3" placeholder="What this feature does…"></textarea>
                </div>
              </div>
            </div>
          </template>

          <template id="tpl-simple-feature">
            <div class="a-builder-row js-sf-row">
              <input type="text" class="js-sf-label" placeholder="Short label" />
              <button type="button" class="a-btn a-btn--ghost a-btn--sm js-sf-remove" aria-label="Remove row">×</button>
            </div>
          </template>

          <template id="tpl-sub-project">
            <div class="a-builder-card js-sp-card">
              <div class="a-builder-card__toolbar">
                <span class="a-builder-card__label">Module</span>
                <button type="button" class="a-btn a-btn--ghost a-btn--sm js-sp-remove">Remove</button>
              </div>
              <div class="admin-form-cols admin-form-cols--wide">
                <div class="a-field">
                  <label>Name</label>
                  <input type="text" class="js-sp-name" placeholder="Module name" />
                </div>
                <div class="a-field">
                  <label>Lucide icon</label>
                  <input type="text" class="js-sp-icon" placeholder="layers" autocomplete="off" spellcheck="false" />
                </div>
                <div class="a-field admin-col-full">
                  <label>Short summary</label>
                  <input type="text" class="js-sp-desc" placeholder="One line summary" />
                </div>
                <div class="a-field admin-col-full">
                  <label>Full description</label>
                  <textarea class="js-sp-fulldesc" rows="3" placeholder="Longer copy"></textarea>
                </div>
                <div class="a-field admin-col-full">
                  <label>Bullet features (one per line)</label>
                  <textarea class="js-sp-features" rows="5" placeholder="One bullet per line"></textarea>
                </div>
              </div>
            </div>
          </template>

        </div><!-- /p-case -->

        <!-- ═══ PANEL 3 — Results & testimonial ════════════════ -->
        <div id="p-results" class="a-panel">

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">03 — Results & impact</span>
            </div>
            <div class="admin-section__body">
              <p class="a-section-lede">Hero stats appear near the top of the case study; outcome tiles fill the “Measurable outcomes” grid — add rows below, no JSON.</p>

              <div class="a-builder-section">
                <h4 class="a-builder-section__title">Stats bar (hero numbers)</h4>
                <p class="a-builder-section__hint">Usually three compact metrics: a label (e.g. “Students”) and a bold value (e.g. “2K+”).</p>
                <div id="statsBuilder" class="a-builder-stack">
                  <% (project.stats || []).forEach(function (st, idx) { %>
                  <div class="a-builder-row a-builder-row--stat js-stat-row">
                    <input type="text" class="js-stat-label" value="<%= st.label || '' %>" placeholder="Label" />
                    <input type="text" class="js-stat-value" value="<%= st.value || '' %>" placeholder="2K+" />
                    <button type="button" class="a-btn a-btn--ghost a-btn--sm js-stat-remove" aria-label="Remove stat">×</button>
                  </div>
                  <% }); %>
                </div>
                <button type="button" class="a-btn a-btn--ghost a-builder-add" id="addStatRow">+ Add stat</button>
              </div>

              <div class="a-builder-section a-builder-section--divider">
                <h4 class="a-builder-section__title">Measurable outcomes</h4>
                <p class="a-builder-section__hint">Each tile needs a prominent value, a short headline, and optional supporting sentence.</p>
                <div id="resultsBuilder" class="a-builder-stack">
                  <% (project.results || []).forEach(function (r, idx) { %>
                  <div class="a-builder-card js-result-card">
                    <div class="a-builder-card__toolbar">
                      <span class="a-builder-card__label">Outcome <%= idx + 1 %></span>
                      <button type="button" class="a-btn a-btn--ghost a-btn--sm js-result-remove">Remove</button>
                    </div>
                    <div class="admin-form-cols admin-form-cols--wide">
                      <div class="a-field">
                        <label>Value (large)</label>
                        <input type="text" class="js-result-value" value="<%= r.value || '' %>" placeholder="60%" />
                      </div>
                      <div class="a-field admin-col-full">
                        <label>Headline</label>
                        <input type="text" class="js-result-label" value="<%= r.label || '' %>" placeholder="Time saved" />
                      </div>
                      <div class="a-field admin-col-full">
                        <label>Description</label>
                        <textarea class="js-result-desc" rows="2" placeholder="Supporting context for visitors…"><%= r.desc || '' %></textarea>
                      </div>
                    </div>
                  </div>
                  <% }); %>
                </div>
                <button type="button" class="a-btn a-btn--ghost a-builder-add" id="addResultCard">+ Add outcome</button>
              </div>

              <textarea id="statsJson" name="statsJson" class="a-json-hidden" aria-hidden="true"><%- JSON.stringify(project.stats || []) %></textarea>
              <textarea id="resultsJson" name="resultsJson" class="a-json-hidden" aria-hidden="true"><%- JSON.stringify(project.results || []) %></textarea>
            </div>
          </div>

          <template id="tpl-stat-row">
            <div class="a-builder-row a-builder-row--stat js-stat-row">
              <input type="text" class="js-stat-label" placeholder="Label" />
              <input type="text" class="js-stat-value" placeholder="2K+" />
              <button type="button" class="a-btn a-btn--ghost a-btn--sm js-stat-remove" aria-label="Remove stat">×</button>
            </div>
          </template>

          <template id="tpl-result-card">
            <div class="a-builder-card js-result-card">
              <div class="a-builder-card__toolbar">
                <span class="a-builder-card__label">Outcome</span>
                <button type="button" class="a-btn a-btn--ghost a-btn--sm js-result-remove">Remove</button>
              </div>
              <div class="admin-form-cols admin-form-cols--wide">
                <div class="a-field">
                  <label>Value (large)</label>
                  <input type="text" class="js-result-value" placeholder="60%" />
                </div>
                <div class="a-field admin-col-full">
                  <label>Headline</label>
                  <input type="text" class="js-result-label" placeholder="Time saved" />
                </div>
                <div class="a-field admin-col-full">
                  <label>Description</label>
                  <textarea class="js-result-desc" rows="2" placeholder="Supporting context…"></textarea>
                </div>
              </div>
            </div>
          </template>

          <div class="admin-section">
            <div class="admin-section__head">
              <span class="admin-section__title">Client testimonial</span>
            </div>
            <div class="admin-section__body">
              <div class="admin-form-cols admin-form-cols--wide">
                <div class="a-field admin-col-full">
                  <label for="testimonialQuote">Quote</label>
                  <textarea id="testimonialQuote" name="testimonialQuote" rows="4" placeholder="What the client said…"><%= project.testimonial&&project.testimonial.quote ? project.testimonial.quote : '' %></textarea>
                </div>
                <div class="a-field">
                  <label for="testimonialName">Full name</label>
                  <input type="text" id="testimonialName" name="testimonialName" value="<%= project.testimonial&&project.testimonial.name ? project.testimonial.name : '' %>" placeholder="John Doe" />
                </div>
                <div class="a-field">
                  <label for="testimonialRole">Role / title</label>
                  <input type="text" id="testimonialRole" name="testimonialRole" value="<%= project.testimonial&&project.testimonial.role ? project.testimonial.role : '' %>" placeholder="CEO, Acme Corp" />
                </div>
                <div class="a-field">
                  <label for="testimonialAvatar">Avatar initials</label>
                  <input type="text" id="testimonialAvatar" name="testimonialAvatar" value="<%= project.testimonial&&project.testimonial.avatar ? project.testimonial.avatar : '' %>" maxlength="3" placeholder="JD" />
                </div>
              </div>
            </div>
          </div>

        </div><!-- /p-results -->

        <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:24px;padding-top:16px;border-top:1px solid var(--a-border);">
          <a href="/admin" class="a-btn a-btn--ghost">Cancel</a>
          <button type="submit" class="a-btn a-btn--primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Save project
          </button>
        </div>

      </form>
    </div><!-- /admin-content -->
  </div><!-- /admin-main -->
</div><!-- /admin-app -->

<script>
(function () {
  /* Tab switching */
  var tabs   = document.querySelectorAll('.a-tab');
  var panels = document.querySelectorAll('.a-panel');
  tabs.forEach(function (t) {
    t.addEventListener('click', function () {
      var target = t.getAttribute('data-panel');
      tabs.forEach(function (x) { x.classList.remove('active'); });
      panels.forEach(function (p) { p.classList.remove('active'); });
      t.classList.add('active');
      var panel = document.getElementById(target);
      if (panel) panel.classList.add('active');
    });
  });

  /* Color picker sync */
  var pick   = document.getElementById('colorPick');
  var hexIn  = document.getElementById('color');
  var swatch = document.getElementById('colorSwatch');
  function setAccentHex(hex) {
    if (!pick || !hexIn || !swatch || !/^#[0-9A-Fa-f]{6}$/i.test(hex)) return;
    pick.value = hex;
    hexIn.value = hex;
    swatch.style.background = hex;
  }
  if (pick && hexIn && swatch) {
    pick.addEventListener('input', function () {
      hexIn.value = pick.value;
      swatch.style.background = pick.value;
    });
    hexIn.addEventListener('input', function () {
      if (/^#[0-9A-Fa-f]{6}$/.test(hexIn.value)) {
        pick.value = hexIn.value;
        swatch.style.background = hexIn.value;
      }
    });
  }

  function rgbToHex(rgb) {
    if (!rgb) return null;
    var m = rgb.match(/^rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/i);
    if (!m) return null;
    return '#' + [m[1], m[2], m[3]].map(function (n) {
      var h = parseInt(n, 10).toString(16);
      return h.length === 1 ? '0' + h : h;
    }).join('');
  }

  document.querySelectorAll('.a-color-preset[data-qvar]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var varName = btn.getAttribute('data-qvar');
      if (!varName || !pick || !hexIn || !swatch) return;
      var probe = document.createElement('span');
      probe.setAttribute('style', 'position:absolute;left:-9999px;top:0;width:1px;height:1px;pointer-events:none;visibility:hidden;background-color:var(' + varName + ');');
      document.body.appendChild(probe);
      var rgb = getComputedStyle(probe).backgroundColor;
      document.body.removeChild(probe);
      var hex = rgbToHex(rgb);
      if (hex) setAccentHex(hex);
    });
  });

  var catPreset = document.getElementById('categoryPreset');
  var catInput = document.getElementById('category');
  if (catPreset && catInput) {
    var cv = (catInput.value || '').trim();
    for (var ci = 0; ci < catPreset.options.length; ci++) {
      if (catPreset.options[ci].value === cv) {
        catPreset.selectedIndex = ci;
        break;
      }
    }
    catPreset.addEventListener('change', function () {
      if (catPreset.value) catInput.value = catPreset.value;
    });
  }

  var iconPreset = document.getElementById('iconPreset');
  var iconInput = document.getElementById('icon');
  if (iconPreset && iconInput) {
    var iv = (iconInput.value || '').trim() || 'layers';
    var iconFound = false;
    for (var ii = 0; ii < iconPreset.options.length; ii++) {
      if (iconPreset.options[ii].value === iv) {
        iconPreset.selectedIndex = ii;
        iconFound = true;
        break;
      }
    }
    if (!iconFound) iconPreset.selectedIndex = 0;
    iconPreset.addEventListener('change', function () {
      if (iconPreset.value) iconInput.value = iconPreset.value;
    });
  }

  /* Technologies — checkbox dropdown */
  var techToggle = document.getElementById('techToggle');
  var techPanel = document.getElementById('techPanel');
  var techSummary = document.getElementById('techSummary');
  var techSearch = document.getElementById('techSearch');
  var techMultiselect = document.getElementById('techMultiselect');

  function updateTechSummary() {
    if (!techSummary || !techMultiselect) return;
    var boxes = techMultiselect.querySelectorAll('input[type="checkbox"][name="technologies"]');
    var n = 0;
    boxes.forEach(function (cb) { if (cb.checked) n++; });
    var other = document.getElementById('technologiesOther');
    var extra = 0;
    if (other && other.value.trim()) {
      other.value.split(/[,|\n]/).forEach(function (s) {
        if (s.trim()) extra++;
      });
    }
    if (n === 0 && extra === 0) techSummary.textContent = 'Select technologies…';
    else if (extra === 0) techSummary.textContent = n + ' selected';
    else techSummary.textContent = n + ' from list, +' + extra + ' extra';
  }

  function closeTechPanel() {
    if (!techPanel || !techToggle) return;
    techPanel.setAttribute('hidden', '');
    techToggle.setAttribute('aria-expanded', 'false');
  }

  function openTechPanel() {
    if (!techPanel || !techToggle) return;
    techPanel.removeAttribute('hidden');
    techToggle.setAttribute('aria-expanded', 'true');
    if (techSearch && techMultiselect) {
      techSearch.value = '';
      techMultiselect.querySelectorAll('.a-tech-multiselect__item').forEach(function (row) {
        row.style.display = '';
      });
      techSearch.focus();
      techSearch.select();
    }
  }

  if (techToggle && techPanel && techMultiselect) {
    techToggle.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      var isOpen = !techPanel.hasAttribute('hidden');
      if (isOpen) closeTechPanel();
      else openTechPanel();
    });
    document.addEventListener('click', function (ev) {
      if (!techMultiselect.contains(ev.target)) closeTechPanel();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && techPanel && !techPanel.hasAttribute('hidden')) closeTechPanel();
    });
  }

  if (techSearch && techMultiselect) {
    techSearch.addEventListener('input', function () {
      var q = techSearch.value.trim().toLowerCase();
      techMultiselect.querySelectorAll('.a-tech-multiselect__item').forEach(function (row) {
        var span = row.querySelector('span');
        var txt = span ? span.textContent.toLowerCase() : '';
        row.style.display = !q || txt.indexOf(q) !== -1 ? '' : 'none';
      });
    });
    techSearch.addEventListener('click', function (e) { e.stopPropagation(); });
  }

  if (techMultiselect) {
    techMultiselect.querySelectorAll('input[type="checkbox"][name="technologies"]').forEach(function (cb) {
      cb.addEventListener('change', updateTechSummary);
    });
    var otherTech = document.getElementById('technologiesOther');
    if (otherTech) otherTech.addEventListener('input', updateTechSummary);
    updateTechSummary();
  }

  /* Case study builders → JSON fields (submit) */
  function gatherFullFeatures() {
    var out = [];
    document.querySelectorAll('#fullFeaturesBuilder .js-ff-row').forEach(function (row) {
      var icon = (row.querySelector('.js-ff-icon') && row.querySelector('.js-ff-icon').value || '').trim();
      var title = (row.querySelector('.js-ff-title') && row.querySelector('.js-ff-title').value || '').trim();
      var desc = (row.querySelector('.js-ff-desc') && row.querySelector('.js-ff-desc').value || '').trim();
      if (!title && !desc && !icon) return;
      out.push({ icon: icon || 'star', title: title, desc: desc });
    });
    return out;
  }

  function gatherSimpleFeatures() {
    var out = [];
    document.querySelectorAll('#simpleFeaturesBuilder .js-sf-row .js-sf-label').forEach(function (inp) {
      var v = (inp.value || '').trim();
      if (v) out.push(v);
    });
    return out;
  }

  function gatherSubProjects() {
    var out = [];
    document.querySelectorAll('#subProjectsBuilder .js-sp-card').forEach(function (card) {
      var name = (card.querySelector('.js-sp-name') && card.querySelector('.js-sp-name').value || '').trim();
      var icon = (card.querySelector('.js-sp-icon') && card.querySelector('.js-sp-icon').value || '').trim() || 'layers';
      var desc = (card.querySelector('.js-sp-desc') && card.querySelector('.js-sp-desc').value || '').trim();
      var fullDescEl = card.querySelector('.js-sp-fulldesc');
      var fullDesc = fullDescEl ? String(fullDescEl.value || '').trim() : '';
      var featTxt = card.querySelector('.js-sp-features');
      var features = featTxt
        ? featTxt.value.split(/\r?\n/).map(function (s) { return s.trim(); }).filter(Boolean)
        : [];
      if (!name && !desc && !fullDesc && features.length === 0) return;
      out.push({
        name: name,
        icon: icon,
        desc: desc,
        fullDesc: fullDesc || desc,
        features: features
      });
    });
    return out;
  }

  function gatherStats() {
    var out = [];
    document.querySelectorAll('#statsBuilder .js-stat-row').forEach(function (row) {
      var label = (row.querySelector('.js-stat-label') && row.querySelector('.js-stat-label').value || '').trim();
      var value = (row.querySelector('.js-stat-value') && row.querySelector('.js-stat-value').value || '').trim();
      if (!label && !value) return;
      out.push({ label: label, value: value });
    });
    return out;
  }

  function gatherResults() {
    var out = [];
    document.querySelectorAll('#resultsBuilder .js-result-card').forEach(function (card) {
      var value = (card.querySelector('.js-result-value') && card.querySelector('.js-result-value').value || '').trim();
      var label = (card.querySelector('.js-result-label') && card.querySelector('.js-result-label').value || '').trim();
      var desc = (card.querySelector('.js-result-desc') && card.querySelector('.js-result-desc').value || '').trim();
      if (!value && !label && !desc) return;
      out.push({ value: value, label: label, desc: desc });
    });
    return out;
  }

  function syncCaseStudyJsonFields() {
    var ffEl = document.getElementById('fullFeaturesJson');
    var sfEl = document.getElementById('featuresJson');
    var spEl = document.getElementById('subProjectsJson');
    var stEl = document.getElementById('statsJson');
    var resEl = document.getElementById('resultsJson');
    if (ffEl) ffEl.value = JSON.stringify(gatherFullFeatures());
    if (sfEl) sfEl.value = JSON.stringify(gatherSimpleFeatures());
    if (spEl) spEl.value = JSON.stringify(gatherSubProjects());
    if (stEl) stEl.value = JSON.stringify(gatherStats());
    if (resEl) resEl.value = JSON.stringify(gatherResults());
  }

  function syncExtraImagesJson() {
    var ta = document.getElementById('extraImagesJson');
    if (!ta) return;
    var urls = [];
    document.querySelectorAll('#extraWebUrlBuilder .js-extra-url').forEach(function (inp) {
      var v = (inp.value || '').trim();
      if (v) urls.push(v);
    });
    ta.value = JSON.stringify(urls);
  }

  function refreshExtraWebThumb(row) {
    if (!row) return;
    var inp = row.querySelector('.js-extra-url');
    var img = row.querySelector('.js-extra-thumb');
    if (!inp || !img) return;
    var v = (inp.value || '').trim();
    img.onerror = function () {
      row.classList.add('is-extra-thumb-broken');
      img.hidden = true;
    };
    img.onload = function () {
      row.classList.remove('is-extra-thumb-broken');
      img.hidden = false;
    };
    if (!v) {
      img.removeAttribute('src');
      img.hidden = true;
      row.classList.add('is-extra-url-empty');
      row.classList.remove('is-extra-thumb-broken');
      return;
    }
    row.classList.remove('is-extra-url-empty');
    img.hidden = false;
    img.src = v;
  }

  function syncMobileScreenshotsJson() {
    var ta = document.getElementById('mobileScreenshotsJson');
    if (!ta) return;
    var rows = [];
    document.querySelectorAll('#mobileShotsBuilder .js-mobile-shot').forEach(function (card) {
      var url = (card.getAttribute('data-url') || '').trim();
      var c = card.querySelector('.js-msc-caption');
      var cap = c ? String(c.value || '').trim() : '';
      if (url) rows.push({ url: url, caption: cap });
    });
    ta.value = JSON.stringify(rows);
  }

  var extraWebPreviewUrls = [];
  var mobileNewPreviewUrls = [];
  function revokeUrlList(list) {
    list.forEach(function (u) {
      try { URL.revokeObjectURL(u); } catch (e) { /* ignore */ }
    });
    list.length = 0;
  }

  function mergeImageFilesIntoInput(input, newFileList) {
    if (!input) return;
    var dt = new DataTransfer();
    var i;
    if (input.files && input.files.length) {
      for (i = 0; i < input.files.length; i++) dt.items.add(input.files[i]);
    }
    var arr = newFileList.length !== undefined ? Array.prototype.slice.call(newFileList) : [];
    for (i = 0; i < arr.length; i++) {
      if (arr[i] && /^image\//.test(arr[i].type)) dt.items.add(arr[i]);
    }
    input.files = dt.files;
    input.dispatchEvent(new Event('change', { bubbles: true }));
  }

  function wireMediaDropzone(zoneEl, fileInput) {
    if (!zoneEl || !fileInput) return;
    ['dragenter', 'dragover'].forEach(function (ev) {
      zoneEl.addEventListener(ev, function (e) {
        e.preventDefault();
        e.stopPropagation();
        zoneEl.classList.add('is-dragover');
      });
    });
    zoneEl.addEventListener('dragleave', function (e) {
      e.preventDefault();
      e.stopPropagation();
      if (!zoneEl.contains(e.relatedTarget)) zoneEl.classList.remove('is-dragover');
    });
    zoneEl.addEventListener('drop', function (e) {
      e.preventDefault();
      e.stopPropagation();
      zoneEl.classList.remove('is-dragover');
      var fl = e.dataTransfer && e.dataTransfer.files;
      if (!fl || !fl.length) return;
      mergeImageFilesIntoInput(fileInput, fl);
    });
  }

  function rebuildExtraWebPreviews(input) {
    var strip = document.getElementById('extraWebPreviewStrip');
    if (!strip) return;
    revokeUrlList(extraWebPreviewUrls);
    strip.innerHTML = '';
    if (!input || !input.files || !input.files.length) {
      strip.hidden = true;
      return;
    }
    strip.hidden = false;
    for (var i = 0; i < input.files.length; i++) {
      var f = input.files[i];
      if (!/^image\//.test(f.type)) continue;
      var u = URL.createObjectURL(f);
      extraWebPreviewUrls.push(u);
      var wrap = document.createElement('div');
      wrap.className = 'a-media-strip__item';
      var im = document.createElement('img');
      im.src = u;
      im.alt = f.name || '';
      wrap.appendChild(im);
      strip.appendChild(wrap);
    }
  }

  function rebuildMobileNewPreviews(input) {
    var grid = document.getElementById('mobileNewPreviewGrid');
    if (!grid) return;
    revokeUrlList(mobileNewPreviewUrls);
    grid.innerHTML = '';
    if (!input || !input.files || !input.files.length) return;
    var idx = 0;
    for (var i = 0; i < input.files.length; i++) {
      var f = input.files[i];
      if (!/^image\//.test(f.type)) continue;
      var u = URL.createObjectURL(f);
      mobileNewPreviewUrls.push(u);
      var card = document.createElement('div');
      card.className = 'a-media-new-card';
      var th = document.createElement('div');
      th.className = 'a-media-new-card__thumb';
      var img = document.createElement('img');
      img.src = u;
      img.alt = f.name || '';
      th.appendChild(img);
      var capId = 'mnew-cap-' + Date.now() + '-' + i + '-' + Math.random().toString(36).slice(2, 8);
      var lab = document.createElement('label');
      lab.className = 'a-media-new-card__label';
      lab.setAttribute('for', capId);
      lab.textContent = 'Caption';
      var cap = document.createElement('input');
      cap.type = 'text';
      cap.name = 'mobileNewCaptions';
      cap.id = capId;
      cap.placeholder = 'e.g. Home';
      card.appendChild(th);
      card.appendChild(lab);
      card.appendChild(cap);
      grid.appendChild(card);
      idx++;
    }
  }

  var projectForm = document.getElementById('project-form');
  if (projectForm) {
    projectForm.addEventListener('submit', function () {
      syncCaseStudyJsonFields();
      syncExtraImagesJson();
      syncMobileScreenshotsJson();
    });
  }

  function tplAppend(tplId, containerId) {
    var tpl = document.getElementById(tplId);
    var box = document.getElementById(containerId);
    if (!tpl || !tpl.content || !box) return;
    box.appendChild(document.importNode(tpl.content, true));
  }

  var addFf = document.getElementById('addFullFeature');
  var ffBox = document.getElementById('fullFeaturesBuilder');
  if (addFf && ffBox) {
    addFf.addEventListener('click', function () {
      tplAppend('tpl-full-feature', 'fullFeaturesBuilder');
    });
    ffBox.addEventListener('click', function (e) {
      if (e.target.closest('.js-ff-remove')) {
        var row = e.target.closest('.js-ff-row');
        if (row) row.remove();
      }
    });
  }

  var addSf = document.getElementById('addSimpleFeature');
  var sfBox = document.getElementById('simpleFeaturesBuilder');
  if (addSf && sfBox) {
    addSf.addEventListener('click', function () {
      tplAppend('tpl-simple-feature', 'simpleFeaturesBuilder');
    });
    sfBox.addEventListener('click', function (e) {
      if (e.target.closest('.js-sf-remove')) {
        var row = e.target.closest('.js-sf-row');
        if (row) row.remove();
      }
    });
  }

  function syncEcosystemUi() {
    var cb = document.getElementById('isEcosystem');
    var badge = document.getElementById('ecosystemBadge');
    var banner = document.getElementById('ecosystemInactiveBanner');
    if (!cb) return;
    var on = cb.checked;
    if (banner) banner.style.display = on ? 'none' : '';
    if (badge) {
      var n = document.querySelectorAll('#subProjectsBuilder .js-sp-card').length;
      if (!on) badge.textContent = 'Off';
      else if (n === 0) badge.textContent = 'On — add modules';
      else badge.textContent = 'On · ' + n + ' module' + (n === 1 ? '' : 's');
    }
  }

  var ecoCb = document.getElementById('isEcosystem');
  if (ecoCb) ecoCb.addEventListener('change', syncEcosystemUi);

  var addSp = document.getElementById('addSubProject');
  var spBox = document.getElementById('subProjectsBuilder');
  if (addSp && spBox) {
    addSp.addEventListener('click', function () {
      tplAppend('tpl-sub-project', 'subProjectsBuilder');
      syncEcosystemUi();
    });
    spBox.addEventListener('click', function (e) {
      if (e.target.closest('.js-sp-remove')) {
        var card = e.target.closest('.js-sp-card');
        if (card) card.remove();
        syncEcosystemUi();
      }
    });
  }
  syncEcosystemUi();

  var addStat = document.getElementById('addStatRow');
  var statBox = document.getElementById('statsBuilder');
  if (addStat && statBox) {
    addStat.addEventListener('click', function () {
      tplAppend('tpl-stat-row', 'statsBuilder');
    });
    statBox.addEventListener('click', function (e) {
      if (e.target.closest('.js-stat-remove')) {
        var row = e.target.closest('.js-stat-row');
        if (row) row.remove();
      }
    });
  }

  var addRes = document.getElementById('addResultCard');
  var resBox = document.getElementById('resultsBuilder');
  if (addRes && resBox) {
    addRes.addEventListener('click', function () {
      tplAppend('tpl-result-card', 'resultsBuilder');
    });
    resBox.addEventListener('click', function (e) {
      if (e.target.closest('.js-result-remove')) {
        var card = e.target.closest('.js-result-card');
        if (card) card.remove();
      }
    });
  }

  /* Screenshots — URL builder, drag-drop, previews, per-file captions */
  var extraWebInput = document.getElementById('extraWebImages');
  var extraWebZone = document.getElementById('extraWebDropzone');
  if (extraWebInput) {
    extraWebInput.addEventListener('change', function () { rebuildExtraWebPreviews(extraWebInput); });
  }
  wireMediaDropzone(extraWebZone, extraWebInput);

  var screensInput = document.getElementById('screenshots');
  var mobileZone = document.getElementById('mobileScreensDropzone');
  if (screensInput) {
    screensInput.addEventListener('change', function () { rebuildMobileNewPreviews(screensInput); });
  }
  wireMediaDropzone(mobileZone, screensInput);

  var addExtraUrl = document.getElementById('addExtraUrlRow');
  var extraUrlBox = document.getElementById('extraWebUrlBuilder');
  if (addExtraUrl && extraUrlBox) {
    addExtraUrl.addEventListener('click', function () {
      tplAppend('tpl-extra-url-row', 'extraWebUrlBuilder');
      var rows = extraUrlBox.querySelectorAll('.js-extra-url-row');
      var last = rows[rows.length - 1];
      if (last) {
        var ni = last.querySelector('.js-extra-url');
        if (ni) ni.focus();
      }
    });
    extraUrlBox.addEventListener('input', function (e) {
      if (e.target.classList && e.target.classList.contains('js-extra-url')) {
        refreshExtraWebThumb(e.target.closest('.js-extra-url-row'));
      }
    });
    extraUrlBox.addEventListener('click', function (e) {
      if (e.target.closest('.js-extra-remove')) {
        var row = e.target.closest('.js-extra-url-row');
        if (row) row.remove();
      }
    });
  }

  var mobShotBox = document.getElementById('mobileShotsBuilder');
  if (mobShotBox) {
    mobShotBox.addEventListener('click', function (e) {
      if (e.target.closest('.js-msc-remove')) {
        var card = e.target.closest('.js-mobile-shot');
        if (card) card.remove();
      }
    });
  }

  /* Auto-slug from title */
  var titleEl = document.getElementById('title');
  var slugEl  = document.getElementById('slug');
  if (titleEl && slugEl) {
    titleEl.addEventListener('blur', function () {
      if (!slugEl.value.trim()) {
        var s = titleEl.value.trim().toLowerCase()
          .replace(/[^\w\s-]/g,'').replace(/[\s_-]+/g,'-').replace(/^-+|-+$/g,'');
        slugEl.value = s;
      }
    });
  }

  /* Sidebar toggle */
  var toggle  = document.getElementById('sidebar-toggle');
  var sidebar = document.getElementById('admin-sidebar');
  if (toggle && sidebar) {
    toggle.addEventListener('click', function () { sidebar.classList.toggle('open'); });
  }
  function checkBP() { if (toggle) toggle.style.display = window.innerWidth <= 820 ? '' : 'none'; }
  checkBP();
  window.addEventListener('resize', checkBP);
})();
</script>
</body>
</html>
